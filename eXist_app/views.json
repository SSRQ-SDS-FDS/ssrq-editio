{
  "openapi": "3.0.0",
  "info": {
    "version": "0.0.1",
    "title": "SSRQ · SDS · FDS: Editio Views",
    "description": "This is the API documentation for views of the Editio application."
  },
  "tags": [
    {
      "name": "views",
      "description": "HTML-views generated (mostly by the templating engine)"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "The Home route of editio",
        "tags": ["views"],
        "operationId": "views:home-handler",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "description": "The selected language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["de", "en", "fr", "it"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The home route of editio",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/about/{page}": {
      "get": {
        "summary": "Content pages of the about section; e.g. /about/partners",
        "tags": ["views"],
        "operationId": "views:about-handler",
        "x-error-handler": "views:error-handler",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([a-z]*)$"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "The selected language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["de", "en", "fr", "it"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requestes content page of the about section",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Requested view not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/about/api.json": {
      "get": {
        "summary": "The API documentation as JSON",
        "tags": ["views"],
        "operationId": "views:serve-api-definition",
        "responses": {
          "200": {
            "description": "The API documentation as JSON",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{kanton}": {
      "get": {
        "summary": "List of volumes per Kanton",
        "tags": ["views"],
        "operationId": "views:volumes-per-kanton-handler",
        "x-error-handler": "views:error-handler",
        "parameters": [
          {
            "name": "kanton",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Z]{2})/?$"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "The selected language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["de", "en", "fr", "it"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The list of volumes per Kanton",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "301": {
            "description": "Redirect to the canonical URL, if the route is not ending with a slash",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Requested view not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{kanton}/{volume}": {
      "get": {
        "summary": "List of documents per volume",
        "tags": ["views"],
        "operationId": "views:documents-per-volume-handler",
        "x-error-handler": "views:error-handler",
        "parameters": [
          {
            "name": "kanton",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Z]{2})/?$"
            }
          },
          {
            "name": "volume",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Za-z0-9_]+)/?$"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "The selected language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["de", "en", "fr", "it"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The list of documents per volume",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "301": {
            "description": "Redirect to the canonical URL, if the route is not ending with a slash",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Requested view not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{kanton}/{volume}/{paratext}.html": {
      "get": {
        "summary": "The HTML view of a paratext",
        "tags": ["views"],
        "operationId": "views:paratext-handler",
        "x-error-handler": "views:error-handler",
        "parameters": [
          {
            "name": "kanton",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Z]{2})/?$"
            }
          },
          {
            "name": "volume",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Za-z0-9_]+)/?$"
            }
          },
          {
            "name": "paratext",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^(intro|bailiffs|lit).html$"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "The selected language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["de", "en", "fr", "it"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The HTML view of a paratext",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Requested view not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error encountered",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{kanton}/{volume}/{paratext}.xml": {
      "get": {
        "summary": "The XML view of a paratext",
        "tags": ["views"],
        "operationId": "views:paratext-handler",
        "x-error-handler": "views:error-handler",
        "parameters": [
          {
            "name": "kanton",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Z]{2})/?$"
            }
          },
          {
            "name": "volume",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([A-Za-z0-9_]+)/?$"
            }
          },
          {
            "name": "paratext",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^(intro|bailiffs|lit).xml$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The XML view of a paratext",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Requested view not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error encountered",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
