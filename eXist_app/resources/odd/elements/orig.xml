<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="orig" mode="change">
    <model output="latex" predicate="request:get-parameter('introduction', ())" behaviour="inline">
        <pb:template>\textit{[[content]]}</pb:template>
    </model>
    <model output="latex" behaviour="inline">
        <param name="content" value="replace(replace(., '^ ', ''), ' $', '')"/>
        <pb:template>\textup{[[content]]}</pb:template>
    </model>
    <model predicate="parent::quote" behaviour="inline">
        <param name="content" value="."/>
    </model>
    <model behaviour="inline">
        <param name="content" value="('«', ., '»')"/>
    </model>
</elementSpec>
