<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="figure" mode="change">
    <model predicate="graphic[@mimeType = ('image/svg', 'image/jpg')][@url]" behaviour="image">
        <desc>Display images in editorial paratexts as svg or jpg</desc>
    </model>
    <model predicate="not(parent::label)" behaviour="inline">
        <param name="content" value="ec:translate(@type, false(), true())"/>
        <outputRendition scope="before">
            content: '[';
        </outputRendition>
        <outputRendition scope="after">
            content: ']';
        </outputRendition>
    </model>
</elementSpec>
