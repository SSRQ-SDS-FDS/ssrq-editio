<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="msIdentifier">
    <model output="latex" behaviour="inline">
        <param name="content" value="string-join((idno, altIdentifier/idno), ', ')"/>
    </model>
    <model behaviour="omit" predicate="not(idno/text())"/>
    <modelSequence>
        <model behaviour="listItem">
            <param name="content" value="if (idno[@xml:lang = $parameters?lang ]) then idno[@xml:lang = $parameters?lang ] else idno[1]"/>
        </model>
        <model behaviour="listItem">
            <param name="content" value="altIdentifier/idno"/>
        </model>
    </modelSequence>
</elementSpec>
