<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="sic" mode="change">
    <model output="latex" predicate="$ec:language='fr' and not(parent::choice and count(parent::*/*) gt 1)" behaviour="inline">
        <pb:template>&lt;[[content]]&gt;</pb:template>
    </model>
    <model output="latex" predicate="not(parent::choice and count(parent::*/*) gt 1)" behaviour="inline">
        <pb:template>[[content]]\,[!]</pb:template>
    </model>
    <model predicate="parent::choice and count(parent::*/*) gt 1" behaviour="inline"/>
    <model behaviour="alternate" cssClass="text-critical">
        <param name="default" value="."/>
        <param name="alternate" value="ec:label('sic')"/>
        <param name="type" value="'text-critical'"/>
    </model>
</elementSpec>
