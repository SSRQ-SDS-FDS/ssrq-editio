<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="note" mode="change">
    <model output="latex" predicate="request:get-parameter('introduction', ())" behaviour="inline">
        <pb:template>\footnote{[[content]]}</pb:template>
    </model>
    <model predicate="@place" behaviour="note">
        <param name="place" value="@place"/>
        <param name="label" value="@n"/>
    </model>
    <model behaviour="note">
        <param name="type" value="'note'"/>
    </model>
</elementSpec>
