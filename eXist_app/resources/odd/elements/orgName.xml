<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="orgName" mode="add">
    <model output="latex" behaviour="inline">
        <param name="ref" value="@ref"/>
        <pb:template>\persname{[[ref]]}{[[content]]}</pb:template>
    </model>
    <model behaviour="reference" cssClass="semantic organization">
        <desc>Semantic highlighting of organization names with tooltip and blue text color</desc>
        <param name="content" value="."/>
        <param name="ref" value="@ref"/>
        <param name="label" value="ec:label('organisation')"/>
    </model>
</elementSpec>
