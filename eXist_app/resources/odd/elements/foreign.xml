<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="foreign" mode="change">
    <model output="latex" predicate="$ec:language='fr'" behaviour="inline">
        <pb:template>\textit{[[content]]}</pb:template>
    </model>
    <model output="latex" behaviour="inline"/>
    <model predicate="$ec:language='fr'" behaviour="alternate">
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('lang-switch'), ec:colon(), ' ', ec:label(@xml:lang, false()))"/>
        <outputRendition>
            font-style: italic;
        </outputRendition>
    </model>
    <model behaviour="alternate">
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('lang-switch'), ec:colon(), ' ', ec:label(@xml:lang, false()))"/>
    </model>
</elementSpec>
