<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="time" mode="change">
    <model predicate="@period" behaviour="alternate" cssClass="text-critical">
        <desc>Display time with given parameter in tooltip and highlight text with color</desc>
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('duration'), ec:colon(), ec:translate(@period, false(), false()))"/>
    </model>
    <model predicate="@when" behaviour="alternate" cssClass="text-critical">
        <desc>Display time with given parameter in tooltip and highlight text with color</desc>
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('time'), ec:colon(), format-time(@when, '[H]:[m]'))"/>
    </model>
    <model predicate="@notAfter" behaviour="alternate" cssClass="text-critical">
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('notAfter'), ec:colon(), format-time(@notAfter, '[H]:[m]'))"/>
    </model>
    <model output="web" predicate="@dur-iso[starts-with(., 'R/P')]" behaviour="alternate" cssClass="text-critical">
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('repeated-duration'), ec:colon(), ec:format-duration(substring-after(@dur-iso, 'R/')))"/>
    </model>
    <model predicate="@dur-iso" behaviour="alternate" cssClass="text-critical">
        <desc>Display time in tooltip and highlight text with color</desc>
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('duration'), ec:colon(), ec:format-duration(@dur-iso))"/>
    </model>
    <model predicate="@from and @to" behaviour="alternate" cssClass="text-critical">
        <desc>Display a period of time in tooltip</desc>
        <param name="default" value="."/>
        <param name="alternate" value="(ec:label('duration'), ec:colon(), string-join((ec:label('from', false()), format-time(@from, '[H]:[m]'), ec:label('to', false()), format-time(@to, '[H]:[m]')), ' '))"/>
    </model>
    <model behaviour="alternate" cssClass="text-critical">
        <desc>Display time in tooltip and highlight text with color</desc>
        <param name="default" value="."/>
        <param name="alternate" value="ec:label('time')"/>
    </model>
</elementSpec>
