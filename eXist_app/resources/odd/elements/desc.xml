<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="desc" mode="change">
    <model predicate="parent::dataSpec[ancestor::TEI/@type = 'abbr'] and @xml:lang = $ec:language" behaviour="heading">
        <desc>Spezifisches Rendering von Beschreibungen im Abkürzungsverzeichnis</desc>
        <param name="level" value="3"/>
    </model>
    <model predicate="parent::valItem[ancestor::TEI/@type = 'abbr'] and @xml:lang = $ec:language" behaviour="listItem">
        <desc>Spezifisches Rendering von Beschreibungen im Abkürzungsverzeichnis</desc>
    </model>
    <model predicate="ancestor::dataSpec[@ident = 'ssrq.labels']" behaviour="inline">
        <desc>Auslesen von Übersetzungen aus ssrq.labels</desc>
    </model>
    <model behaviour="omit"/>
</elementSpec>
