                    <model predicate="monogr[not(@type='edition')] and not(analytic) and (@xml:id or monogr/ref)" behaviour="listItem" cssClass="biblio">
                        <param name="author" value="if (ec:format-author(monogr/author)) then (ec:format-author(monogr/author) || ec:colon()) else ()"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'web')"/>
