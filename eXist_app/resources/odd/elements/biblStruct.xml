<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="biblStruct" mode="change">
                    <!-- Rendering von Editionsangaben LaTeX -->
                    <model predicate="monogr[@type='edition'] and (@xml:id =&gt; matches('SSRQ|SDS|FDS'))" behaviour="block" output="latex">
                        <param name="author" value="if (ec:format-editor(monogr/author)) then (', bearb. von ' || ec:format-editor(monogr/author)) else ()"/>
                        <param name="series-ssrq" value="series/title"/>
                        <param name="series-ssrq-scope" value="', ' || series/biblScope =&gt; string-join(' ') || ec:colon()"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="monogr/title[@type='short']"/>
                        <param name="place" value="', ' || string-join(distinct-values(monogr/imprint/pubPlace), '/') || ' '"/>
                        <param name="date" value="monogr/imprint/date[1]/text()"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Selbstständige Edition aus der SSRQ-Reihe
                            <div>[[series-ssrq]][[series-ssrq-scope]][[title]][[author]][[place]][[date]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model predicate="monogr[@type='edition']" behaviour="block" output="latex">
                        <param name="author" value="if (ec:format-editor(monogr/author)) then (', bearb. von ' || ec:format-editor(monogr/author)) else ()"/>
                        <param name="series" value="if (series) then ec:join-series-with-scope(series) else ()"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="monogr/title[@type='short']"/>
                        <param name="place" value="string-join(distinct-values(monogr/imprint/pubPlace), '/') || ' '"/>
                        <param name="date" value="monogr/imprint/date[1]/text()"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Selbstständige Edition
                            <div>[[title]][[author]], [[series]][[place]][[date]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model predicate="analytic[@type='edition']" behaviour="block" output="latex">
                        <param name="author" value="if (ec:format-editor(analytic/author)) then (', bearb. von ' || ec:format-editor(analytic/author)) else ()"/>
                        <param name="title" value="ec:render-title-with-hi(analytic/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="analytic/title[@type='short']"/>
                        <param name="journal" value="monogr/title"/>
                        <param name="editor" value="if(monogr/author) then ec:format-editor(monogr/author) || ' (' || ec:label('editor', false()) || ')' || ', ' else ()"/>
                        <param name="series-biblscope" value="ec:parse-biblScope(., 'series')"/>
                        <param name="place" value="if (monogr/imprint) then ', ' || string-join(monogr/imprint/pubPlace, '/') || ' ' || monogr/imprint/date[1] else ()"/>
                        <param name="scope" value="ec:parse-biblScope(., 'scope')"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Unselbstständige Edition
                            <div>[[title]][[author]], in: [[editor]][[journal]][[series-biblscope]][[place]][[scope]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model predicate="monogr[@type='enc']" behaviour="block" output="latex">
                        <param name="editor" value="ec:format-editor(monogr/author) || ' (' || ec:label('editor', false()) || ')'"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="monogr/title[@type='short']"/>
                        <param name="place" value="string-join(distinct-values(monogr/imprint/pubPlace), '/') || ' '"/>
                        <param name="date" value="monogr/imprint/date[1]/text()"/>
                        <param name="additional-infos" value="if (monogr/imprint/biblScope) then ', ' || monogr/imprint/biblScope else()"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Lexika
                            <div>[[title]], [[editor]], [[place]][[date]][[additional-infos]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model predicate="monogr[not(@type='edition')] and not(analytic)" behaviour="block" output="latex">
                        <param name="author" value="if (ec:format-author(monogr/author)) then (ec:format-author(monogr/author) || ': ') else ()"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="monogr/title[@type='short']"/>
                        <param name="series" value="if (series) then ec:join-series-with-scope(series) else ()"/>
                        <param name="thesis-statement" value="if (monogr/note) then monogr/note =&gt; tokenize(' ') =&gt; head() || ', ' else ()"/>
                        <param name="place" value="string-join(distinct-values(monogr/imprint/pubPlace), '/') || ' '"/>
                        <param name="date" value="monogr/imprint/date[1]/text()"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Selbstständige Publikation
                            <div>[[author]][[title]], [[series]][[thesis-statement]][[place]][[date]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model predicate="analytic[not(@type='edition')]" behaviour="block" output="latex">
                        <param name="author" value="if (ec:format-author(analytic/author)) then (ec:format-author(analytic/author) || ': ') else ()"/>
                        <param name="title" value="ec:render-title-with-hi(analytic/title[not(@type='short')], 'latex')"/>
                        <param name="short-title" value="analytic/title[@type='short']"/>
                        <param name="journal" value="monogr/title"/>
                        <param name="series-biblscope" value="ec:parse-biblScope(., 'series')"/>
                        <param name="editor" value="if(monogr/author) then ec:format-editor(monogr/author) || ' (' || ec:label('editor', false()) || ')' || ', ' else ()"/>
                        <param name="place" value="if (monogr/imprint) then ', ' || string-join(monogr/imprint/pubPlace, '/') || ' ' || monogr/imprint/date[1] else ()"/>
                        <param name="scope" value="ec:parse-biblScope(., 'scope')"/>
                        <pb:template xmlns="" xml:space="preserve">
                            % Unselbstständige Publikation
                            <div>[[author]][[title]], in: [[editor]][[journal]][[series-biblscope]][[place]][[scope]] ([[short-title]]).
                            </div>
                        </pb:template>
                    </model>
                    <model output="latex" behaviour="omit"/>
                    <!-- Rendering von Editionsangaben WEB -->
                    <model predicate="monogr[@type='edition'] and (@xml:id or monogr/ref) and (@xml:id =&gt; matches('SSRQ|SDS|FDS'))" behaviour="listItem" cssClass="biblio">
                        <param name="author" value="if (ec:format-editor(monogr/author)) then (', ' || ec:label('edited-by', false()) || ' ' || ec:format-editor(monogr/author)) else ()"/>
                        <param name="series-ssrq" value="series/title"/>
                        <param name="series-ssrq-scope" value="', ' || series/biblScope =&gt; string-join(' ') || ec:colon()"/>
                        <param name="title" value="ec:render-title-with-hi(monogr/title[not(@type='short')], 'web')"/>
                        <param name="short-title" value="monogr/title[@type='short']"/>
                        <param name="link" value="if (monogr/ref) then monogr/ref/@target else ec:format-link(@xml:id)"/>
                        <param name="place" value="', ' || string-join(distinct-values(monogr/imprint/pubPlace), '/') || ' '"/>
                        <param name="date" value="monogr/imprint/date[1]/text()"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <!--  SSRQ Edition mit externem Verweis -->
                            <div>[[series-ssrq]][[series-ssrq-scope]][[title]][[author]][[place]][[date]] (<a href="[[link]]" target="_bibl">[[short-title]]</a>).
                            </div>
                        </pb:template>
                    </model>
