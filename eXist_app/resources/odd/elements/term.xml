<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="term" mode="change">
    <!--<model output="latex" predicate="not(*)" behaviour="omit"/>-->
    <model output="latex" behaviour="inline">
        <param name="ref" value="@ref"/>
        <pb:template>\term{[[ref]]}{[[content]]}</pb:template>
    </model>
    <model behaviour="reference" cssClass="semantic term">
        <desc>Semantic highlighting of keywords and lemmata with dark-red text color</desc>
        <param name="content" value="."/>
        <param name="ref" value="@ref"/>
        <param name="label" value="ec:label('term')"/>
    </model>
</elementSpec>
