<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://ssrq-sds-fds.ch/exist/apps/ssrq/i18n/module" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="persName" mode="add">
    <model output="latex" behaviour="inline">
        <param name="ref" value="@ref"/>
        <pb:template>\persname{[[ref]]}{[[content]]}</pb:template>
    </model>
    <model behaviour="reference" cssClass="semantic person">
        <desc>Semantic highlighting of person with blue text color</desc>
        <param name="content" value="."/>
        <param name="ref" value="@ref"/>
        <param name="label" value="ec:label('person')"/>
    </model>
</elementSpec>
