<?xml version="1.0" encoding="UTF-8"?>
<project default="xar" name="ssrq">
    <property file="local.build.properties"/>
    <property file="build.properties"/>
    <xmlproperty file="expath-pkg.xml"/>
    <property name="project.version" value="${package(version)}"/>
    <property name="project.app" value="ssrq"/>
    <property name="build.dir" value="build"/>
    <target name="xar">
        <mkdir dir="${build.dir}"/>
        <zip basedir="." destfile="${build.dir}/${project.app}-${project.version}.xar" excludes="${build.dir}/* node_modules/** test/** resources/scss/**"/>
        <mkdir dir="${build.dir}/resources/css"/>
        <echo message="Compiling SCSS..."/>
        <exec executable="sassc" outputproperty="sassc.output">
            <arg line="-tcompressed"/>
            <arg line="-mauto"/>
            <arg line="./resources/scss/style.css"/>
            <arg line="${build.dir}/resources/css/style.css"/>
        </exec>
        <echo message="${sassc.output}"/>
    </target>
    <target name="clean">
	<delete dir="${build.dir}"/>
    </target>
</project>
