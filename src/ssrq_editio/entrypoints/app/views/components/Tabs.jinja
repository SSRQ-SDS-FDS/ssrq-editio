{# def
    data: list[tuple[str, str]],
#}
<div class="flex flex-col w-full flex-1" x-data="{active_tab: '{{ data[0]["tab"] }}'}">
    <nav class="flex gap-4 px-4 mb-2 pb-2 border-ssrq-greyed-500 border-b-2">
        {% for d in data %}
            <div>
                <span
                    x-on:click="active_tab='{{ d["tab"] }}'"
                    x-bind:class="active_tab=='{{ d["tab"] }}' ? 'text-ssrq-greyed-900 border-b-2 border-b-ssrq-primary' : 'text-ssrq-greyed-500 hover:text-ssrq-primary'"
                    class="cursor-pointer text-ssrq-greyed-500"
                >
                    {{ d["tab"] }}
                </span>
            </div>
        {% endfor %}
    </nav>
    {% for d in data %}
        <div id="col_left" class="flex-1 rounded-lg shadow-md p-4" x-show="active_tab=='{{ d["tab"] }}'" x-cloak>
        {% set context = d["context"] %}
        {% include d["template"] with context %}
        </div>
    {% endfor %}
</div>
