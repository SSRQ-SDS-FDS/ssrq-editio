{# def
lang: Lang,
request: Request,
translator: Translator
#}
{% set about_routes = [
    ('partners_and_funding', 'partners_and_funding'),
    ('editorial_principles','https://schema.ssrq-sds-fds.ch/latest/'),
    ('tech', 'tech'),
    ('api', 'swagger_ui_html')
    ]
%}
{% set index_routes = [
    ('lemmata', url_for('entity_view', entity_type = 'lemmata').include_query_params(lang=lang.value)),
    ('terms', url_for('entity_view', entity_type = 'keywords').include_query_params(lang=lang.value)),
    ('places', url_for('entity_view', entity_type = 'places').include_query_params(lang=lang.value)),
    ('persons', url_for('entity_view', entity_type = 'persons').include_query_params(lang=lang.value)),
    ('families', url_for('entity_view', entity_type = 'families').include_query_params(lang=lang.value)),
    ('organizations', url_for('entity_view', entity_type = 'organizations').include_query_params(lang=lang.value)),
]%}
<header x-data="{ open: false }">
    <nav class="bg-ssrq-secondary z-30 fixed shadow h-16 w-full sm:px-4 lg:px-12 py-1 flex items-center border-t-4 border-t-ssrq-primary">
        <div class="flex justify-between sm:flex-grow-1 w-full lg:w-auto">
            <a href="{{ url_for('index').include_query_params(lang=lang.value) }}">
                <img src="{{ url_for('static', path='images/ssrq-logo.png') }}"
                     class="w-auto max-h-12 pb-1.5"
                     alt="SSRQ · SDS · FDS Logo" />
            </a>
            <button type="button"
                    class="text-ssrq-greyed-700 hover:text-ssrq-primary focus:outline-none focus:text-gray-600 lg:hidden"
                    aria-label="toggle menu"
                    @click="open = !open">
                <svg xmlns="http://www.w3.org/2000/svg"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke-width="1.5"
                     stroke="currentColor"
                     class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5" />
                </svg>
            </button>
        </div>
        <div class="hidden lg:flex flex-grow-1 px-2">
            <NavDropdown
              :items="index_routes"
              :lang="lang"
              :main_entry="'index'"
              :request="request"
              :translator="translator"
            />
            <NavDropdown
              :items="about_routes"
              :lang="lang"
              :main_entry="'project'"
              :request="request"
              :translator="translator"
            />
            <a
                href="mailto:info@ssrq-sds-fds.ch"
                title="Mail"
                class="menu-link"
                aria-label="Mail"
            >
                Feedback
            </a>
        </div>
        <div class="hidden ml-auto lg:flex items-center">
            <SearchBar
              :lang="lang"
              :request="request"
              :translator="translator"
            />
            <LangSelector
              :lang="lang"
              :request="request"
              :translator="translator"
            />
        </div>
    </nav>
    <template x-if="open">
        <div x-data="{ show: false }"
             x-init="$nextTick(() => { show = true })"
             x-show="show"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="transform translate-x-full"
             x-transition:enter-end="transform translate-x-0"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="transform translate-x-0"
             x-transition:leave-end="transform translate-x-full"
             class="bg-ssrq-greyed-50 w-64 fixed top-0 right-0 h-full z-50 transform border-t-4 border-t-ssrq-primary">
            <!-- Mobile Menu close button -->
            <button class="mobile-menu-close-button absolute top-0 right-0 p-4 focus:outline-none"
                    x-on:click="open = !open">
                <svg class="hover:text-ssrq-primary w-5 h-5 text-ssrq-greyed-700"
                     fill="none"
                     stroke="currentColor"
                     viewBox="0 0 24 24"
                     xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
            <div class="flex flex-col items-start p-4 h-full">
                <a
                  class="menu-link"
                  href="{{ url_for('search') }}"
                >
                    {{ translator.translate(lang, 'search') }}
                </a>
                <NavDropdown
                    :items="index_routes"
                    :lang="lang"
                    :main_entry="'index'"
                    :request="request"
                    :translator="translator"
                    class="is-mobile"
                />
               <NavDropdown
                  :items="about_routes"
                  :lang="lang"
                  :main_entry="'project'"
                  :request="request"
                  :translator="translator"
                  class="is-mobile"
                />
                <div class="mt-auto border-t-2 border-t-ssrq-greyed-500 w-full">
                    <h6 class="mt-1 px-2.5 text-sm font-semibold">
                        <i18n:text key="additional-languages">
                        Sprache
                        </i18n:text>
                    </h6>
                    <ul class="mobile-lang-selector">
                        <LangListItems :lang="lang" :request="request" />
                    </ul>
                </div>
            </div>
        </div>
    </template>
    <template x-if="open">
        <div @click="open = !open"
             class="fixed inset-0 bg-black bg-opacity-50 z-20"></div>
    </template>
</header>
