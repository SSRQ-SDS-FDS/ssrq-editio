{# def
    document: tuple[Document, Sequence[str] | None],
    lang: Lang,
    request: Request,
    translator: Translator
#}

{% set doc = document[0] %}
{% set orig_places = document[1] %}

<article class="document-info">
    <header>
        <span title="{{ translator.translate(lang, 'ssrq-idno') }}">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-3.5 h-3.5 mr-0.5 md:mr-1"
            >
                <path
                    fill-rule="evenodd"
                    d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0                                    0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5z"
                    clip-rule="evenodd"
                />
            </svg>
            {{ doc.printed_idno }}
        </span>
        <span title="{{ translator.translate(lang, 'orig-date') }}">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-3.5 h-3.5 mr-0.5 md:mr-1"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                />
            </svg>
            {{ doc[lang.value + '_orig_date'] | safe }}
        </span>
        {% if doc.orig_place is not none and orig_places | length > 0 %}
            <span title="{{ translator.translate(lang, 'orig-place') }}">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-3.5 h-3.5 mr-0.5 md:mr-1"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                    />
                </svg>
                {{ orig_places | join(', ') }}
            </span>
        {% endif %}
        {% if doc.facs is not none %}
            <span title="{{ translator.translate(lang, 'has-facs') }}">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-3.5 h-3.5 mr-0.5 md:mr-1"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25                                            6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                    />
                </svg>
            </span>

        {% endif %}
    </header>

    {% if lang.value == 'fr' %}
        {{ doc.fr_title | safe }}
    {% else %}
        {{ doc.de_title | safe }}
    {% endif %}

    <footer class="mt-4 flex">
        {#  ToDo: Use a better solution here (supporting uuids etc.) ... #}
        {% set idno_parts = doc.idno.split('-') %}
        <a
            href="{{ url_for('document_view', kanton=idno_parts[1], volume=idno_parts[2] | replace(' ', '_') | replace('/', '_'), document=idno_parts[3:] | join('-') ).include_query_params(lang=lang.value) }}"
        >
            {{ translator.translate(lang, 'view-article') }}
        </a>
        {# ToDo: Insert the correct link here #}
        <a
            href="{{ url_for('document_view', kanton=idno_parts[1], volume=idno_parts[2] | replace(' ', '_') | replace('/', '_'), document=idno_parts[3:] | join('-') ).include_query_params(lang=lang.value) }}">
            {{ translator.translate(lang, 'xml-download') }}
        </a>

    </footer>
</article>