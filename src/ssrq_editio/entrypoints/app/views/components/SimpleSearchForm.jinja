{# def
    endpoint: URL,
    placeholder: str,
    lang: Lang,
    translator: Translator,
    query: str | None,
    hx: bool = False,
    hx_indicator: str | None = None,
    hx_params: str | None = None,
    hx_target: str | None = None
#}

<form
  class="my-2 text-sm"
>
    <label
      for="quickSearchForm"
      class="block mb-2 text-xs text-ssrq-greyed-700"
    >
        {{ translator.translate(lang,'filter-hits') }}
    </label>
    <div
      class="flex item-center"
    >
        <input
          id="quickSearchForm"
          type="text"
          autocomplete="off"
          name="query"
          class="px-4 py-1 min-w-[16rem] text-sm text-ssrq-greyed-800 bg-white border rounded-md focus:border-ssrq-primary focus:border-[0.025rem] focus:outline-none focus:ring focus:ring-ssrq-primary focus:ring-opacity-40"
          placeholder="{{ translator.translate(lang, placeholder) }}"
          {% if query %}value="{{ query }}"{% endif %}
          {% if hx %}
           hx-get="{{ endpoint }}"
           hx-indicator="{{ hx_indicator }}"
           hx-params="{{ hx_params }}"
           hx-target="{{ hx_target }}"
           hx-push-url="true"
           hx-trigger="input changed delay:500ms, submit"
           hx-swap="outerHTML"
          {% endif %}
        />
        <a
          href="{{ endpoint }}"
          class="px-4 py-2 text-sm font-medium text-white transition-colors duration-300 transform bg-ssrq-primary rounded-md ml-1 hover:shadow-sm focus:outline-none focus:shadow-sm"
        >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-3.5 h-3.5"
            >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
                />
            </svg>
        </a>
    </div>
</form>
