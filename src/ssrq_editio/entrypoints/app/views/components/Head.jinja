{# def
    description: str = "Editio",
    favicon: str,
    stylesheets: list[str],
    title: str
#}
<head>
    <title>{{ title }}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description }}" />
    <link rel="shortcut icon" href="{{ favicon }}" />
    {% for stylesheet in stylesheets %}<link rel="stylesheet" type="text/css" href="{{ stylesheet }}"/>{% endfor %}
</head>
