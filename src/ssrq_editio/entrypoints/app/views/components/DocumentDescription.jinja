{# def
    descriptions: list[DocumentDescription],
    lang: Lang,
    request: Request,
    translator: Translator,
    additional_data: dict[str, Any] | None = None
#}

{% macro render_section(content, heading=None, render_type='safe') %}
    {% if content is not none %}
        {% if heading %}
            <h4>{{ heading }}</h4>
        {% endif %}
        {% if render_type == 'template' %}
            {{ content | render_template_string(additional_data) }}
        {% else %}
            {{ content | safe }}
        {% endif %}
    {% endif %}
{% endmacro %}

{% for desc in descriptions %}
    <div class="ssrq-info-card">
        <h3>
            <span>
                {{desc.heading.witnessNumber}}&nbsp;
                {% if desc.heading.witnessNumber is none or desc.heading.witnessNumber == "" or desc.heading.witnessNumber == "A" %}
                    {{ translator.translate(lang, 'base_document') }}
                {% else %}
                    {{ translator.translate(lang, 'additional_witness') }}
                {% endif %}
            </span>
            <span>
                <IdIcon />
                {{desc.heading.idno}}
            </span>
            <span>
                <LangIcon />
                {{desc.heading.lang}}
            </span>
        </h3>

        {{ render_section(desc.archival_information) }}
        {{ render_section(desc.ms_information, render_type='template') }}
        {{ render_section(desc.ms_history, render_type='template') }}
        {{ render_section(desc.admin_info) }}
        {{ render_section(desc.physical_description, translator.translate(lang, 'physical_description'), 'template') }}
        {{ render_section(desc.bibliographic_information, translator.translate(lang, 'bibliography')) }}
    </div>
{% endfor %}
