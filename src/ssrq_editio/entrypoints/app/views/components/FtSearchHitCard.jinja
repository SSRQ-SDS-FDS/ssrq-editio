{# def
    document: DocumentFulltextResult,
    lang: Lang,
    request: Request,
    translator: Translator
#}

{# ToDo: Use a better solution here (supporting uuids etc.) ... #}
{% set idno_parts = document.idno.split('-') %}

<a
    class="w-full"
    href="{{ url_for('document_view', kanton=idno_parts[1], volume=idno_parts[2] | replace(' ', '_') | replace('/', '_'), document=idno_parts[3:] | join('-') ).include_query_params(lang=lang.value) }}"
>
    <article class="document-info">
        <header>
            <span title="{{ translator.translate(lang, 'ssrq-idno') }}">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-3.5 h-3.5 mr-0.5 md:mr-1"
                >
                    <path fill-rule="evenodd"
                        d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5z"
                        clip-rule="evenodd" />
                </svg>
                {{ document.printed_idno }}
            </span>
        </header>

        <p class="font-serif">{{ document.ft_match | safe }}</p>

    </article>
</a>