{% extends "layouts/page.jinja" %}
{% block content %}

<section class="w-full max-w-[1680px] mx-auto px-4 my-4">
    <DocumentNavigation
        :lang="lang"
        :request="request"
        :translator="translator"
        :volume="data.content.volume"
        :document_prev="data.content.document_prev"
        :document_next="data.content.document_next"
    />
</section>

<section class="w-full max-w-[1680px] mx-auto my-4 px-4">
    <h1 class="title-1">{{ data.content.title }}</h1>
</section>

<section class="md:flex w-full max-w-[1680px] mx-auto items-stretch justify-center gap-4 mb-4 px-4">
    <div class="md:w-1/2 flex mb-6 md:mb-0">
        <Tabs :data="data.content.left_col" />
    </div>
    <div class="md:w-1/2 flex items-stretch">
        <Tabs :data="data.content.right_col" />
    </div>
</section>

{% endblock %}
