{% extends "layouts/page.jinja" %}
{% block content %}
    <section class="max-w-4xl lg:px-12 sm:px-4 mx-auto my-48">
        <div class="mx-auto flex w-full max-w-sm overflow-hidden bg-ssrq-secondary rounded-lg shadow-md">
            <div class="flex items-center justify-center w-28 bg-ssrq-primary">
                <svg class="w-12 h-12 text-white fill-current" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 3.36667C10.8167 3.36667 3.3667 10.8167 3.3667 20C3.3667 29.1833 10.8167 36.6333 20 36.6333C29.1834 36.6333 36.6334 29.1833 36.6334 20C36.6334 10.8167 29.1834 3.36667 20 3.36667ZM19.1334 33.3333V22.9H13.3334L21.6667 6.66667V17.1H27.25L19.1334 33.3333Z"/>
                </svg>
            </div>

            <div class="px-4 py-2 -mx-3">
                <div class="mx-3 text-center">
                    <span class="font-semibold text-ssrq-greyed-800"> {{ translator.translate(lang, 'error_title') }}</span>
                    <p class="text-sm my-4 text-ssrq-primary hover:underline cursor-pointer">
                        <a href="/">{{ translator.translate(lang, 'back_to_home') }}</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
