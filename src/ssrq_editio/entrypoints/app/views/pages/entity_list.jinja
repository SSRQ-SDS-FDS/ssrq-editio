{% extends "layouts/page.jinja" %}
{% block content %}
<Banner :request="request">
    <h1
      class="title-1 flex items-center">
      {{translator.translate(lang, 'index-of-' + data.content.entity_type)}}
      <a href="{{ url_for('info_edition' )}}#{{ data.content.entity_type }}" class="icon link-button">
        <InfoButton />
        </a>
    </h1>
</Banner>
<Breadcrumbs
  :request="request"
  :parts="[(translator.translate(lang, data.content.entity_type), None)]"
/>
<section class="flex w-full max-w-5xl lg:px-12 sm:px-4 items-center justify-start mx-auto">
    <EntitySearchForm
      :endpoint="url_for('entity_view', entity_type = data.content.entity_type)"
      :placeholder_id_name="'id-or-name'"
      :placeholder_occurrence="'occurrence'"
      :lang="lang"
      :translator="translator"
      :query="data.content.query"
      :occurrence="data.content.occurrence"
      :volumes="data.content.volumes"
      :hx="True"
      :hx_indicator="'#loading-overlay'"
      :hx_params="'not per-page,page lang'"
      :hx_target="'#entities'"
    />
</section>
{% block entities %}
<section class="entities relative" id="entities">
    <Loader :lang="lang" :translator="translator" />
    {% if data.content.entities %}
        <Pagination
          class="top"
          :current_page="data.content.current_page"
          :pages="data.content.pages"
          :request="request"
        >
            <HitCounter
                :lang="lang"
                :request="request"
                :translator="translator"
                :total="data.content.total"
            />
        </Pagination>
            {% for hit in data.content.entities %}
                {% if data.content.entity_type in ("families", "persons", "organizations") %}
                <EntityCard
                    :entity="hit[0]"
                    :resolved_location="hit[1]"
                    :entity_type="data.content.entity_type"
                    :idnos="data.content.idnos"
                    :lang="lang"
                    :request="request"
                    :translator="translator"
                />
                {% else %}
                <EntityCard
                    :entity="hit"
                    :resolved_location="None"
                    :entity_type="data.content.entity_type"
                    :idnos="data.content.idnos"
                    :lang="lang"
                    :request="request"
                    :translator="translator"
                />
                {% endif %}
            {% endfor %}
        <Pagination
          class="bottom"
          :current_page="data.content.current_page"
          :pages="data.content.pages"
          :request="request"
        />
    {% else %}
        <NoHits
          :lang="lang"
          :translator="translator"
        />
    {% endif %}
</section>
{% endblock %}

{% endblock %}
