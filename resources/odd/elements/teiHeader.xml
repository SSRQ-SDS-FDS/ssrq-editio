<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" mode="change" ident="teiHeader">
    <model output="latex" behaviour="section">
        <desc xml:lang="de" versionDate="2022-11-03">TEI2LaTeX Template für Metadaten</desc>
        <param name="idno" value="//seriesStmt[@xml:id='ssrq-sds-fds']/idno"/>
        <param name="sourceDesc" value="//sourceDesc"/>
        <pb:template>
            \linenumbers				% Zeilennummern
            \normalsize					% normale Grösse, d.h. Quellentext (source) ist 10pt

            \thispagestyle{firstpage}

            [[idno]]
            \fussy
            [[sourceDesc]]
        </pb:template>
    </model>
</elementSpec>
