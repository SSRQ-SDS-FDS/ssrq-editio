<elementSpec xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xmlns:i18n="http://exist-db.org/xquery/i18n" xmlns:nontei="http://ssrq-sds-fds.ch/ns/nonTEI" ident="label" mode="change">
    <model output="latex" predicate="@type='keyword'" behaviour="inline">
        <param name="content" value="."/>
        <pb:template>\marginpar{\scriptsize\raggedright\hspace{0pt}[[content]]}</pb:template>
    </model>
    <model predicate="@type='keyword'" behaviour="alternote">
        <param name="alternate" value="(ec:label('marginal-note'), ' ', ec:translate(@place, false(), false()), if (@scribe) then (' ', ec:label('byScribe', false()), ' ', ec:scribe(@scribe)) else ())"/>
        <!--<param name="content" value="('/ ', .,  ' /')"/>-->
        <param name="type" value="'text-critical'"/>
        <outputRendition>
            font-size: 80%;
        </outputRendition>
    </model>
    <model behaviour="paragraph"/>
</elementSpec>
