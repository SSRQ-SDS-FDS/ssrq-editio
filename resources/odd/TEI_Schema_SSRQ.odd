                        <attDef ident="n" mode="delete"/>
                        <attDef ident="precision" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="stdDeviation" mode="delete"/>
                        <attDef ident="target" mode="delete"/>
                    </attList>
                </elementSpec>
