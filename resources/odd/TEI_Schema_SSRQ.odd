                <elementSpec ident="measure" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <constraintSpec scheme="isoschematron" module="core" ident="sch-measure"
                        mode="change">
                        <desc>Attributes of tei:measure</desc>
                        <constraint>
                            <sch:pattern>
                                <sch:rule
                                    context="tei:measure[matches(@unit,'^(Ballen|Bürde|Dutzend|Fuder|Gaden|Loden|Maschen|Paar|Schubkarre|Seil|Sester|Stock|Stuck|Zeine)$')]">
                                    <sch:assert test="exists(@type)">If @unit is specified on the
                                        <sch:name/> element, @type must be present,
                                        too.</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='area']">
                                    <sch:assert
                                    	test="matches(@unit,'^(Fuss|Gertel|Hube|Juchart|Klafter|Kuhsömmerung|Kuhwinterung|Mal|Mannmad|Mannwerk|Mitmal|Rute|Schritt|Schuh|Schuppose|Staffel|Tagwen|Vierdung|Vierling)$')"
                                        >kein gültiges Flächenmass</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='currency']">
                                    <sch:assert
                                        test="matches(@unit,'^(Angster|fl|lb|ß|xr|d|Dukat|bz|h|M|plp|Böhmischer Groschen|Grossi|k|Ort|Vierer|Spagürli|S|Taler|L)$')"
                                        >keine gültige Währung</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='length']">
                                    <sch:assert
                                        test="matches(@unit,'^(Daumen|Elle|Fuss|Klafter|Meile|Schuh|Stab|Vierling|Zoll)$')"
                                        >kein gültiges Längenmass</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='volume']">
                                    <sch:assert
                                        test="matches(@unit,'^(Becher|Eimer|Garbe|Immi|Kratten|Ledi|Malter|Mütt|Sack|Scheffel|Sester|Ster|Vierdung|Vierling|Viertel|Brenten|Fass|Kopf|Klafter|Legel|Mass|Quart|Quartane|Saum|Schaffen|Tonne|Viertel|Zuber|Fass|Krötli|Röhrchen|Scheibe|Trinken)$')"
                                        >kein gültiges Hohlmass</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='weight']">
                                    <sch:assert
                                        test="matches(@unit,'^(Biner|Gewäg|Krinne|Lot|Pfund|Rupp|Quentli|Vierling|Unze|Zentner)$')"
                                        >kein gültiges Gewicht</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='age']">
                                    <sch:assert test="@unit='year'">keine gültige Einheit für
                                        Alter</sch:assert>
                                </sch:rule>
                                <sch:rule context="tei:measure[@type='undefined']">
                                    <sch:assert
                                        test="matches(@unit,'^(Ballen|Bürde|Dutzend|Fuder|Gaden|Kloben|Loden|Maschen|Paar|Riste|Schubkarre|Seil|Sester|Stock|Stuck|Zeine)$')"
                                        >keine gültige Einheit für ungefähre
                                        Masse/Gewichte</sch:assert>
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec>
                    <attList>
