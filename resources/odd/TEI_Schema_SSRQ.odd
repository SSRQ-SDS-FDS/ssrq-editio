                        <memberOf key="att.global"/>
                    </classes> -->
                    <content>
                        <rng:text/>
                    </content>
                    <attList>
                        <attDef ident="key" mode="replace">
                            <desc xml:lang="de">Tätigkeit, für die ein Bearbeiter verantwortlich
                                ist</desc>
                            <valList type="closed">
                                <valItem ident="transcript">
                                    <desc xml:lang="de">Transkript</desc>
