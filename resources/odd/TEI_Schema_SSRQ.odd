                <elementSpec ident="sic" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="pb"/>
                                <rng:ref name="lb"/>
                                <rng:ref name="note"/>
                           <rng:ref name="subst"/>
