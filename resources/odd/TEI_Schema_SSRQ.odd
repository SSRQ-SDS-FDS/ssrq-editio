                <elementSpec ident="del" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="hand" mode="replace">
                            <desc xml:lang="de">gibt Informationen zur Streichung des Textes</desc>
                            <valList type="closed">
                                <valItem ident="later hand">
                                    <desc xml:lang="de">von späterer Hand</desc>
                                    <desc xml:lang="fr">écrit d'une autre main</desc>
                                    <!-- Text in den Anmerkungen -->
                                </valItem>
                                <valItem ident="other hand">
                                    <desc xml:lang="de">von anderer Hand</desc>
                                    <desc xml:lang="fr">d'un main plus récente</desc>
                                    <!-- Text im Haupttext -->
                                </valItem>
                                <valItem ident="other ink">
                                    <desc xml:lang="de">mit anderer Tinte</desc>
                                    <desc xml:lang="fr">avec une autre encre</desc>
                                </valItem>
                                <valItem ident="pencil">
                                    <desc xml:lang="de">mit Bleistift</desc>
                                    <desc xml:lang="fr">avec un crayon</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="rend" mode="replace">
                            <desc xml:lang="de">gibt wieder, wie eine Streichung vorgenommen
                                wurde</desc>
                            <valList type="closed">
                                <valItem ident="blackened">
                                    <desc xml:lang="de">Streichung durch Schwärzen</desc>
                                    <desc xml:lang="fr">la suppréssion a été noircie</desc>
                                </valItem>
                                <valItem ident="bracketed">
                                    <desc xml:lang="de">Streichung durch Verwendung von
                                        Klammern</desc>
                                    <desc xml:lang="fr">la suppression se trouve entre parenthèses</desc>
                                </valItem>
                                <valItem ident="crossout">
                                    <desc xml:lang="de">Streichung durch gekreuzte Linien</desc>
                                    <desc xml:lang="fr">la suppression a été biffée avec deux lignes croisées</desc>
                                </valItem>
                                <valItem ident="rubbing">
                                    <desc xml:lang="de">Streichung durch Textlöschung/Rasur</desc>
                                    <desc xml:lang="fr">la suppression a été grattée</desc>
                                </valItem>
                                <valItem ident="overwritten">
                                    <desc xml:lang="de">Streichung durch direkte Überschreibung des
