                        <attDef ident="place" mode="replace" usage="req">
                            <desc xml:lang="de">Ort einer Ergänzung</desc>
                            <valList type="closed">
                                <valItem ident="above">
                                    <desc xml:lang="de">oberhalb der Zeile</desc>
                                    <desc xml:lang="fr">au-dessus d'une ligne</desc>
                                </valItem>
                                <valItem ident="below">
                                    <desc xml:lang="de">unterhalb der Zeile</desc>
                                    <desc xml:lang="fr">au-dessous d'une ligne</desc>
                                </valItem>
                                <valItem ident="cover">
                                    <desc xml:lang="de">auf dem Umschlag</desc>
                                    <desc xml:lang="fr">sur le couverture</desc>
                                </valItem>
                                <valItem ident="cover above">
                                    <desc xml:lang="de">auf dem Umschlag oben</desc>
                                    <desc xml:lang="fr">en haut de la couverture</desc>
