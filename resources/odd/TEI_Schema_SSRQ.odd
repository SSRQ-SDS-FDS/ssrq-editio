                                    <sch:assert test="@agent" xml:lang="en">The @agent attribute
                                        must be specified on the <sch:name/> element.</sch:assert>
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec>
                    <attList>
                        <attDef ident="agent" mode="replace" usage="req">
                            <desc xml:lang="de">beschreibt die Art einer Beschädigung</desc>
