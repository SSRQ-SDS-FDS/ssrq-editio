                                    <desc xml:lang="fr">en bas de la couverture</desc>
                                </valItem>
                                <valItem ident="bottom">
                                    <desc xml:lang="de">am unteren Rand</desc>
                                    <desc xml:lang="fr">en bas</desc>
                                </valItem>
                                <valItem ident="inline">
                                    <desc xml:lang="de">auf Zeilenhöhe</desc>
                                    <desc xml:lang="fr">à l'hauteur de la ligne</desc>
                                </valItem>
                                <valItem ident="interlinear">
                                    <desc xml:lang="de">zwischen zwei Zeilen</desc>
                                    <desc xml:lang="fr">entre les ligne</desc>
                                </valItem>
                                <valItem ident="left margin">
                                    <desc xml:lang="de">am linken Rand</desc>
                                    <desc xml:lang="fr">sur la marge gauche</desc>
                                </valItem>
                                <valItem ident="next page">
                                    <desc xml:lang="de">nächste Seite</desc>
                                    <desc xml:lang="fr">sur la page suivante</desc>
                                </valItem>
                                <valItem ident="opposite">
