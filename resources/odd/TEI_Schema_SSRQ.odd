                        </valItem>
                        <valItem ident="language">
                            <desc xml:lang="de">Sprache</desc>
                            <desc xml:lang="fr">Langue</desc>
                        </valItem>
                    </valList>
                </dataSpec>
            </schemaSpec>

            <!--END ODD SCHEMA SPEC-->
        </body>
    </text>
</TEI>
