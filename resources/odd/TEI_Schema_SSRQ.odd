                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 6 unterbaum teiHeader/fileDesc/sourceDesc/listWit/witness/ -->
                <elementSpec ident="msDesc" module="msdescription" mode="change">
                    <content>
                        <rng:choice>
                            <!-- Die "alten" Dateien beinhalten physDesc, die "neuen" mit dem vollständigen TEI-Header das korrekte msDesc -->
                            <rng:ref name="physDesc"/>
                            <rng:group>
                                <rng:ref name="msIdentifier"/>
                                <rng:zeroOrMore>
                                    <rng:ref name="model.headLike"/>
                                </rng:zeroOrMore>
                                <rng:choice>
                                    <rng:oneOrMore>
                                        <rng:ref name="model.pLike"/>
                                    </rng:oneOrMore>
                                    <rng:group>
                                        <rng:optional>
                                            <rng:ref name="msContents"/>
                                        </rng:optional>
                                        <rng:optional>
                                            <rng:ref name="physDesc"/>
                                        </rng:optional>
                                        <rng:optional>
                                            <rng:ref name="history"/>
                                        </rng:optional>
                                        <rng:optional>
                                            <rng:ref name="additional"/>
                                        </rng:optional>
                                    </rng:group>
                                </rng:choice>
                            </rng:group>
                        </rng:choice>
                    </content>
                </elementSpec>
                <!-- ebene 7 unterbaum teiHeader/fileDesc/titleStmt/respStmt/persNam/choice -->
                <elementSpec ident="abbr" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
