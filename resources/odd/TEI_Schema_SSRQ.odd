                                    <desc xml:lang="fr">la suppression a été remplacée directement</desc>
                                </valItem>
                               <valItem ident="strikethrough">
                                    <desc xml:lang="de">Streichung durch einfache
                                        Durchstreichung</desc>
                                    <desc xml:lang="fr">la suppression a été tracée</desc>
                                </valItem>
                                <valItem ident="subpunction">
                                    <desc xml:lang="de">Streichung durch Punkte unter dem zu
                                        Streichenden</desc>
                                    <desc xml:lang="fr">la suppression a été remplacée directement</desc>
                                </valItem>
                                <valItem ident="underline">
                                    <desc xml:lang="de">Streichung mit Unterstreichen</desc>
                                    <desc xml:lang="fr">la suppression a été soulignée</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="cert" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="extent" mode="delete"/>
