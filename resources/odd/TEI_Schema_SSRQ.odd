<?xml version="1.0"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:rng="http://relaxng.org/ns/structure/1.0"
    xmlns:sch="http://purl.oclc.org/dsdl/schematron" xmlns:ssrq="http://ssrq-sds-fds.ch/ns/nonTEI"
    xml:lang="en">
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>Minimal schema for eSSRQ</title>
                <author>Noëmi Aepli</author>
                <author>Pascale Sutter</author>
                <author>Mathias Müller</author>
                <author>Bernhard Ruef</author>
            </titleStmt>
            <publicationStmt>
                <p>for use by whoever wants it</p>
            </publicationStmt>
            <notesStmt>
                <note type="ns">http://ssrq-sds-fds.ch/ns/nonTEI</note>
            </notesStmt>
            <sourceDesc>
                <p>Revision of last commit: $Rev: 139 $</p>
                <p>Date of last commit:     $Date: 2018-01-04 15:45:50 +0100 (Do, 04 Jan 2018) $</p>
                <p>Author of last commit:   $Author: pascale $</p>
            </sourceDesc>
        </fileDesc>
    </teiHeader>
    <text>
        <front>
            <divGen type="toc"/>
        </front>
        <body>
            <p>Beinhaltet alle benötigten TEI-Elemente (auch diejenigen für die
                Retrodigitalisierung) sowie die Siegel-Erweiterungen. Folgende Elemente sind laut
                    <ref target="http://www.ssrq-sds-fds.ch/wiki/index.php?title=Hauptseite"
                    >Wiki</ref> eingeschränkt: titleStmt, title, respStmt, resp, publicationStmt,
                editionStmt, extent, dimensions, seriesStmt, sourceDesc, encodingDesc,
                editorialDecl, profileDesc, textClass, particDesc, settingDesc, revisionDesc,
                facsimile, text, sealDesc, seal, time, occupation, damage</p>

            <!--BEGIN ODD SCHEMA SPEC-->

            <!--  <schemaSpec ident="essrq_2d" docLang="fr" prefix="" xml:lang="en">  -->
            <schemaSpec ident="essrq_2d" docLang="de" xml:lang="en">

                <!--BEGIN MODULE REFERENCES AND ELEMENTS THAT ARE INCLUDED-->

                <moduleRef key="tei"/>
                <moduleRef key="core"
                    include="abbr add author bibl choice corr date del expan foreign gap head hi item label
                    lb list listBibl measure measureGrp note num orig p pb q quote ref reg resp respStmt sic term textLang time title unclear"/>
                <moduleRef key="header"
                    include="textClass profileDesc fileDesc idno editorialDecl encodingDesc extent keywords publicationStmt profileDesc seriesStmt sourceDesc teiHeader textClass titleStmt"/>
                <moduleRef key="textstructure" include="TEI back body div front group signed text"/>
                <moduleRef key="linking" include="ab anchor seg"/>
                <moduleRef key="msdescription"
                    include="altIdentifier origDate origPlace dimensions height width support material condition msDesc physDesc sealDesc objectDesc supportDesc seal msContents history additional repository msItem filiation msIdentifier summary origin"/>
                <moduleRef key="transcr"
                    include="addSpan damage damageSpan delSpan facsimile fw handShift space subst supplied"/>
                <moduleRef key="textcrit" include="app lem listWit rdg witness"/>
                <moduleRef key="namesdates"
                    include="listOrg listPerson listPlace orgName persName placeName"/>
                <moduleRef key="certainty" include="precision"/>
                <moduleRef key="figures" include="figure table row cell"/>
                <moduleRef key="corpus" include="particDesc settingDesc"/>

                <!--END MODULE REFERENCES-->
                <!--BEGIN WHOLESALE DELETIONS OF ATTRIBUTE CLASSES-->

                <classSpec ident="att.edition" type="atts" mode="delete"/>
                <classSpec ident="att.sortable" type="atts" mode="delete"/>
                <classSpec ident="att.cReferencing" type="atts" mode="delete"/>
                <classSpec ident="att.declaring" type="atts" mode="delete"/>
                <classSpec ident="att.ranging" type="atts" mode="delete"/>
                <classSpec ident="att.datable.custom" type="atts" mode="delete"/>
                <classSpec ident="att.datable.iso" type="atts" mode="delete"/>
                <classSpec ident="att.fragmentable" type="atts" mode="delete"/>
                <classSpec ident="att.datcat" type="atts" mode="delete"/>

                <!--END WHOLESALE DELETIONS OF ATTRIBUTE CLASSES-->
                <!--BEGIN CHANGES TO ATTRIBUTE CLASSES-->

                <classSpec ident="att.global" type="atts" mode="change">
                    <classes mode="replace">
                        <memberOf key="att.global.linking"/>
                        <memberOf key="att.global.analytic"/>
                        <memberOf key="att.global.responsibility"/>
                        <memberOf key="att.global.source"/>
                    </classes>
                    <attList>
                        <attDef ident="xml:base" mode="delete"/>
                        <attDef ident="xml:space" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.global.rendition" type="atts" mode="change">
                    <attList>
                        <attDef ident="style" mode="delete"/>
                        <attDef ident="rendition" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.transcriptional" type="atts" mode="change">
                    <attList>
                        <attDef ident="cause" mode="delete"/>
                        <attDef ident="seq" mode="delete"/>
                        <attDef ident="status" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.damaged" type="atts" mode="change">
                    <attList>
                        <attDef ident="group" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.editLike" type="atts" mode="change">
                    <attList>
                        <attDef ident="evidence" mode="delete"/>
                        <attDef ident="instant" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.typed" type="atts" mode="change">
                    <attList>
                        <attDef ident="subtype" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.dimensions" type="atts" mode="change">
                    <attList>
                        <attDef ident="scope" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.pointing" type="atts" mode="change">
                    <attList>
                        <attDef ident="targetLang" mode="delete"/>
                        <attDef ident="evaluate" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.global.linking" type="atts" mode="change">
                    <attList>
                        <attDef ident="synch" mode="delete"/>
                        <attDef ident="copyOf" mode="delete"/>
                        <attDef ident="sameAs" mode="delete"/>
                        <attDef ident="next" mode="delete"/>
                        <attDef ident="prev" mode="delete"/>
                        <attDef ident="exclude" mode="delete"/>
                        <attDef ident="select" mode="delete"/>
                    </attList>
                </classSpec>

                <classSpec ident="att.handFeatures" type="atts" mode="change">
                    <attList>
                        <attDef ident="scribe" mode="replace">
                            <desc>The value is constrained in the Schematron constraint sch-gl-2.</desc>
                            <datatype>
                                <rng:text/>
                            </datatype>
                        </attDef>
                        <attDef ident="scope" mode="delete"/>
                        <attDef ident="scribeRef" mode="delete"/>
                        <attDef ident="script" mode="delete"/>
                        <attDef ident="scriptRef" mode="delete"/>
                    </attList>
                </classSpec>

                <!--END CHANGES TO ATTRIBUTE CLASSES-->
                <!---BEGIN GLOBAL SCH CONSTRAINTS-->

                <constraintSpec scheme="isoschematron" module="core" ident="sch-gl-1" mode="change">
                    <desc>Mutually dependent for all elements: @unit and @quantity</desc>
                    <constraint>
                        <sch:pattern>
                            <sch:rule context="tei:*">
                                <sch:report test="@quantity and not(@unit)" xml:lang="en">If the
                                    @quantity attribute is specified on the <sch:name/> element,
                                    @unit must be present, too.</sch:report>
                                <sch:report test="@unit and not(@quantity)" xml:lang="en">If the
                                    @unit attribute is specified on the <sch:name/> element,
                                    @quantity must be present, too.</sch:report>
                            </sch:rule>
                        </sch:pattern>
                    </constraint>
                </constraintSpec>

               <constraintSpec scheme="isoschematron" module="core" ident="sch-gl-2" mode="change">
                    <desc>Value of @scribe attribute</desc>
                    <constraint>
                        <sch:pattern>
                            <sch:rule context="tei:*">
                                <sch:report test="@scribe[not(matches(.,'^(per\d{6}[abc]?|\d+)$'))]" xml:lang="en"
                                    >Value of the @scribe attribute on the <sch:name/> element is not a person ID or number.</sch:report>
                            </sch:rule>
                        </sch:pattern>
                    </constraint>
                </constraintSpec>

                <!-- wird gar nicht verwendet
                <constraintSpec scheme="isoschematron" ident="sch-damageSpan">
                    <desc>Always required on the damageSpan, delSpan or addSpan element: the @spanTo
                        attribute</desc>
                    <constraint>
                        <sch:pattern>
                            <sch:rule context="tei:addSpan">
                                <sch:assert test="@spanTo"
                                    >The @spanTo attribute must be specified
                                    on the <sch:name/> element.</sch:assert>
                            </sch:rule>
                            <sch:rule context="tei:delSpan">
                                <sch:assert test="@spanTo"
                                    >The @spanTo attribute must be specified
                                    on the <sch:name/> element.</sch:assert>
                            </sch:rule>
                            <sch:rule context="tei:damageSpan">
                                <sch:assert test="@spanTo"
                                    >The @spanTo attribute must be specified
                                    on the <sch:name/> element.</sch:assert>
                            </sch:rule>
                        </sch:pattern>
                    </constraint>
                </constraintSpec>
                -->

                <!--END GLOBAL SCH CONSTRAINTS-->
                <!--BEGIN ADDITIONAL MACROSPECS-->

                <macroSpec ident="macro.defaultContent" mode="add" type="pe">
                    <content>
                        <rng:text/>
                        <!--Textkritische Auszeichnungen-->
                        <rng:ref name="abbr"/>
                        <rng:ref name="add"/>
                        <rng:ref name="addSpan"/>
                        <rng:ref name="app"/>
                        <rng:ref name="corr"/>
                        <rng:ref name="choice"/>
                        <rng:ref name="damage"/>
                        <rng:ref name="damageSpan"/>
                        <rng:ref name="del"/>
                        <rng:ref name="delSpan"/>
                        <rng:ref name="foreign"/>
                        <rng:ref name="gap"/>
                        <rng:ref name="handShift"/>
                        <rng:ref name="note"/>
                        <rng:ref name="sic"/>
                        <rng:ref name="space"/>
                        <rng:ref name="subst"/>
                        <rng:ref name="supplied"/>
                        <rng:ref name="unclear"/>
                        <!--Auszeichnungen, die der Darstellung...-->
                        <rng:ref name="ab"/>
                        <rng:ref name="div"/>
                        <rng:ref name="figure"/>
                        <rng:ref name="head"/>
                        <rng:ref name="hi"/>
                        <rng:ref name="lb"/>
                        <rng:ref name="orig"/>
                    <rng:ref name="p"/>
                        <rng:ref name="pb"/>
                        <rng:ref name="q"/>
                        <rng:ref name="quote"/>
                        <rng:ref name="seg"/>
                        <rng:ref name="signed"/>
                        <rng:ref name="table"/>
                        <!--Inhaltliche Auszeichnungen-->
                        <rng:ref name="date"/>
                        <rng:ref name="origDate"/>
                        <rng:ref name="measure"/>
                        <rng:ref name="measureGrp"/>
                        <rng:ref name="num"/>
                        <rng:ref name="time"/>
                        <!--Registertags-->
                        <rng:ref name="persName"/>
                        <rng:ref name="orgName"/>
                        <rng:ref name="placeName"/>
                        <rng:ref name="origPlace"/>
                        <rng:ref name="term"/>
                    </content>
                </macroSpec>

                <!--END ADDITIONAL MACROSPECS-->
                <!--BEGIN ELEMENT SPECIFICATIONS-->

                <!-- ebene 0 -->
                <elementSpec ident="TEI" module="textstructure" mode="change">
                    <content>
                        <rng:ref name="teiHeader"/>
                        <!--<rng:ref name="facsimile"/>-->
                        <rng:ref name="text"/>
                    </content>
                </elementSpec>
                <!-- ebene 1 unterbaum TEIHEADER -->
                <!-- ebene 1 unterbaum TEI -->
                <elementSpec ident="teiHeader" module="header" mode="change">
                    <content>
                        <rng:group>
                            <rng:ref name="fileDesc"/>
                            <rng:ref name="encodingDesc"/>
                            <rng:zeroOrMore>
                                <rng:ref name="profileDesc"/>
                            </rng:zeroOrMore>
                        </rng:group>
                    </content>
                </elementSpec>
                <!-- ebene 2 unterbaum teiHeader -->
                <elementSpec ident="fileDesc" module="header" mode="change">
                    <content>
                        <rng:group>
                            <rng:group>
                                <rng:ref name="titleStmt"/>
                                <rng:ref name="publicationStmt"/>
                                <rng:optional>
                                    <rng:ref name="seriesStmt"/>
                                </rng:optional>
                            </rng:group>
                            <rng:oneOrMore>
                                <rng:ref name="sourceDesc"/>
                            </rng:oneOrMore>
                        </rng:group>
                    </content>
                </elementSpec>
                <elementSpec ident="encodingDesc" module="header" mode="change">
                    <content>
                        <rng:group>
                                <rng:ref name="editorialDecl"/>
                        </rng:group>
                    </content>
                </elementSpec>
                <elementSpec ident="profileDesc" module="header" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="textClass"/>
                            <rng:ref name="particDesc"/>
                            <rng:ref name="settingDesc"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="particDesc" module="corpus" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="listPerson"/>
                            <rng:ref name="listOrg"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="listPerson" module="namesdates" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="persName"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="listOrg" module="namesdates" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="orgName"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="settingDesc" module="corpus" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="listPlace"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="listPlace" module="namesdates" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="placeName"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <!-- ebene 3 unterbaum teiHeader/fileDesc -->
                <elementSpec ident="titleStmt" module="header" mode="change">
                    <content>
                        <rng:group>
                            <rng:oneOrMore>
                                <rng:ref name="title"/>
                            </rng:oneOrMore>
                            <rng:zeroOrMore>
                                <rng:ref name="respStmt"/>
                            </rng:zeroOrMore>
                        </rng:group>
                    </content>
                </elementSpec>
                <elementSpec ident="publicationStmt" module="header" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:ref name="date"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="seriesStmt" module="header" mode="change">
                    <content>
                        <rng:group>
                            <rng:oneOrMore>
                                <rng:ref name="title"/>
                            </rng:oneOrMore>
                            <rng:zeroOrMore>
                                <rng:choice>
                                    <rng:ref name="respStmt"/>
                                    <rng:ref name="idno"/>
                                </rng:choice>
                            </rng:zeroOrMore>
                        </rng:group>
                    </content>
                </elementSpec>
                <elementSpec ident="sourceDesc" module="header" mode="change">
                    <content>
                        <rng:choice>
                            <!-- Die "alten" Dateien beinhalten listWit, die "neuen" mit dem vollständigen TEI-Header msDesc -->
                            <rng:ref name="listWit"/>
                            <rng:oneOrMore>
                                <rng:ref name="msDesc"/>
                            </rng:oneOrMore>
                        </rng:choice>
                    </content>
                </elementSpec>
                <elementSpec ident="textClass" module="header" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="keywords"/>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>

                <elementSpec ident="msIdentifier" module="msdescription" mode="change">
                    <content>
                        <rng:ref name="idno"/>
                        <rng:optional>
                            <rng:ref name="altIdentifier"/>
                        </rng:optional>
                    </content>
                    <constraintSpec scheme="isoschematron" ident="msId_minimal" mode="delete"/>
                </elementSpec>

                <elementSpec ident="additional" module="msdescription" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:ref name="listBibl"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>

                <!-- ebene 4 unterbaum teiHeader/fileDesc/titleStmt -->
                <elementSpec ident="title" module="core" mode="change">
                    <!-- classes mode="replace">
                        <memberOf key="model.emphLike"/>
                        <memberOf key="model.msQuoteLike"/>
                        <memberOf key="att.global"/>
                    </classes> -->
                    <content>
                        <rng:text/>
                    </content>
                </elementSpec>
                <elementSpec ident="respStmt" module="core" mode="change">
                    <content>
                        <rng:choice>
                            <rng:group>
                                <rng:oneOrMore>
                                    <rng:ref name="resp"/>
                                </rng:oneOrMore>
                                <rng:oneOrMore>
                                    <rng:choice>
                                        <rng:ref name="persName"/>
                                        <rng:ref name="orgName"/>
                                    </rng:choice>
                                </rng:oneOrMore>
                            </rng:group>
                            <rng:group>
                                <rng:oneOrMore>
                                    <rng:choice>
                                        <rng:ref name="persName"/>
                                        <rng:ref name="orgName"/>
                                    </rng:choice>
                                </rng:oneOrMore>
                                <rng:oneOrMore>
                                    <rng:ref name="resp"/>
                                </rng:oneOrMore>
                            </rng:group>
                        </rng:choice>
                    </content>
                </elementSpec>
                <!-- ebene 4 unterbaum teiHeader/fileDesc/publicationStmt -->
                <elementSpec ident="date" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="macro.defaultContent"/>
                                <rng:ref name="precision"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="calendar" mode="replace" usage="opt">
                            <desc xml:lang="de">verwendeter Kalender</desc>
                            <valList type="closed">
                                <valItem ident="annunciation">
                                    <desc xml:lang="de">Annuntiationsstil</desc>
                                    <desc xml:lang="fr">le style de l'Annonciation)</desc>
                                </valItem>
                                <valItem ident="circumcision">
                                    <desc xml:lang="de">Circumcisionsstil</desc>
                                    <desc xml:lang="fr">le style de la Circoncision</desc>
                                </valItem>
                                <valItem ident="Gregorian">
                                    <desc xml:lang="de">Gregorianischer Kalender</desc>
                                    <desc xml:lang="fr">le calendrier grégorien</desc>
                                </valItem>
                                <valItem ident="Julian">
                                    <desc xml:lang="de">Julianischer Kalender</desc>
                                    <desc xml:lang="fr">le calendrier julien</desc>
                                </valItem>
                                <valItem ident="natal">
                                    <desc xml:lang="de">Natalstil</desc>
                                    <desc xml:lang="fr">le style de la Nativité</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="dur" mode="replace">
                            <desc xml:lang="de">Angabe von einer Periode gefolgt von einer Zahl in
                                arabischen Ziffern</desc>
                            <datatype>
                                <rng:text/>
                            </datatype>
                        </attDef>
                        <attDef ident="period" mode="replace" usage="opt">
                            <desc xml:lang="de">benannte Periode</desc>
                            <valList type="closed">
                                <valItem ident="#spring">
                                    <desc xml:lang="de">Frühling</desc>
                                    <desc xml:lang="fr">printemps</desc>
                                </valItem>
                                <valItem ident="#fall">
                                    <desc xml:lang="de">Herbst</desc>
                                    <desc xml:lang="fr">automne</desc>
                                </valItem>
                                <valItem ident="#summer">
                                    <desc xml:lang="de">Sommer</desc>
                                    <desc xml:lang="fr">été</desc>
                                </valItem>
                                <valItem ident="#winter">
                                    <desc xml:lang="de">Winter</desc>
                                    <desc xml:lang="fr">hiver</desc>
                                </valItem>
                                <valItem ident="P1WD">
                                    <desc xml:lang="de">Sonntag</desc>
                                    <desc xml:lang="fr">dimanche</desc>
                                </valItem>
                                <valItem ident="P2WD">
                                    <desc xml:lang="de">Montag</desc>
                                    <desc xml:lang="fr">lundi</desc>
                                </valItem>
                                <valItem ident="P3WD">
                                    <desc xml:lang="de">Dienstag</desc>
                                    <desc xml:lang="fr">mardi</desc>
                                </valItem>
                                <valItem ident="P4WD">
                                    <desc xml:lang="de">Mittwoch</desc>
                                    <desc xml:lang="fr">mercredi</desc>
                                </valItem>
                                <valItem ident="P5WD">
                                    <desc xml:lang="de">Donnerstag</desc>
                                    <desc xml:lang="fr">jeudi</desc>
                                </valItem>
                                <valItem ident="P6WD">
                                    <desc xml:lang="de">Freitag</desc>
                                    <desc xml:lang="fr">vendredi</desc>
                                </valItem>
                                <valItem ident="P7WD">
                                    <desc xml:lang="de">Samstag</desc>
                                    <desc xml:lang="fr">samedi</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="type" mode="replace">
                            <desc xml:lang="de">nähere Charakterisierung einer Datierung, wird für
                                Termine und Fristen verwendet sowie für Art der Publikation</desc>
                            <valList type="closed">
                                <valItem ident="deadline">
                                    <desc xml:lang="de">Termin/Frist</desc>
                                    <desc xml:lang="fr">délai</desc>
                                </valItem>
                                <valItem ident="deadline_holiday">
                                    <desc xml:lang="de">Kirchenfest als Termin/Frist </desc>
                                    <desc xml:lang="fr">des fêtes religieuses comme délai</desc>
                                </valItem>
                                <valItem ident="deadline_floating holiday">
                                    <desc xml:lang="de">Beweglicher Feiertag als Termin/Frist</desc>
                                    <desc xml:lang="fr">des fêtes sans date fixe comme délai</desc>
                                </valItem>
                                <valItem ident="holiday">
                                    <desc xml:lang="de">Kirchenfest</desc>
                                    <desc xml:lang="fr">des fêtes religieuses</desc>
                                </valItem>
                                <valItem ident="floating holiday">
                                    <desc xml:lang="de">Beweglicher Feiertag</desc>
                                    <desc xml:lang="fr">des fêtes sans date fixe</desc>
                                </valItem>
                                <valItem ident="electronic">
                                    <desc xml:lang="de">elektronische Publikation</desc>
                                </valItem>
                                <valItem ident="print">
                                    <desc xml:lang="de">Druck</desc>
                                    <desc xml:lang="fr">imprimé</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="unit" mode="delete"/>
                        <attDef ident="quantity" mode="delete"/>
                        <attDef ident="cert" mode="delete"/>
                        <attDef ident="extent" mode="delete"/>
                        <attDef ident="source" mode="delete"/>
                        <attDef ident="precision" mode="delete"/>
                        <attDef ident="resp" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 4 unterbaum teiHeader/fileDesc/seriesStmt -->
                <elementSpec ident="idno" module="header" mode="change">
                    <content>
                        <rng:text/>
                    </content>
                </elementSpec>
                <!-- ebene 4 unterbaum teiHeader/fileDesc/sourceDesc -->
                <elementSpec ident="listWit" module="textcrit" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:ref name="witness"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>
                <!-- ebene 5 unterbaum teiHeader/fileDesc/titleStmt/respStmt -->
                <elementSpec ident="persName" module="namesdates" mode="change">
                    <!-- classes mode="replace">
                        <memberOf key="model.nameLike.agent"/>
                        <memberOf key="model.persStateLike"/>
                        <memberOf key="att.naming"/>
                        <!- @role ->
                        <memberOf key="att.global"/>
                    </classes> -->
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
