                            <valList type="closed">
                                <valItem ident="0.5">
                                    <desc xml:lang="de">0.5</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="match" mode="replace">
                            <desc xml:lang="de">enthält @notAfter, @notBefore, @from, @to oder
                                @when.</desc>
                            <valList type="closed">
                                <valItem ident="@notAfter">
                                    <desc xml:lang="de">nicht nach</desc>
                                </valItem>
                                <valItem ident="@notBefore">
                                    <desc xml:lang="de">nicht vor</desc>
                                </valItem>
