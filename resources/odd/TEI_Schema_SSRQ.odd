                <elementSpec ident="anchor" module="linking" mode="change">
                    <content>
                        <rng:empty/>
                    </content>
                    <constraintSpec scheme="isoschematron" ident="sch-anchor">
                        <desc>Attributes of tei:anchor</desc>
                        <constraint>
                            <sch:pattern>
                                <sch:rule context="tei:anchor">
                                    <sch:assert test="@xml:id" xml:lang="en">The @xml:id attribute
                                        must be specified on the <sch:name/> element.</sch:assert>
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec>
                    <attList>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="type" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="app" module="textcrit" mode="change">
                    <content>
                        <rng:choice>
                            <rng:group>
                                <rng:ref name="lem"/>
                                <rng:ref name="rdg"/>
                            </rng:group>
                            <rng:group>
                                <rng:ref name="lem"/>
                                <rng:ref name="rdg"/>
                                <rng:ref name="rdg"/>
                            </rng:group>
                        </rng:choice>
                    </content>
                    <attList>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="from" mode="delete"/>
                        <attDef ident="loc" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="to" mode="delete"/>
                        <attDef ident="type" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="bibl" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="ref"/>
                                <rng:text/>
                            </rng:choice>
                        </rng:zeroOrMore>
