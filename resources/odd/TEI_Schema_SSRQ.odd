                <!-- ebene 7 unterbaum teiHeader/fileDesc/sourceDesc/listWit/witness/msDesc/ -->
                <elementSpec ident="physDesc" module="msdescription" mode="change">
                    <content>
                        <rng:optional>
                            <rng:ref name="objectDesc"/>
                        </rng:optional>
                    <rng:optional>
                            <rng:ref name="sealDesc"/>
                        </rng:optional>
                    </content>
                </elementSpec>
                <!-- ebene 8 unterbaum teiHeader/fileDesc/sourceDesc/listWit/witness/msDesc/physDesc-->
                <elementSpec ident="sealDesc" module="msdescription" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:ref name="seal"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>
                <!-- ebene 9 unterbaum teiHeader/fileDesc/sourceDesc/listWit/witness/msDesc/physDesc/sealDesc-->
                <elementSpec ident="seal" module="msdescription" mode="change">
                    <classes mode="change">
                        <memberOf key="att.global.facs"/>
                        <memberOf key="att.datable" mode="delete"/>
                    </classes>
                    <content>
                        <rng:optional>
                            <rng:choice>
                                <rng:ref name="orgName"/>
                                <rng:ref name="persName"/>
                            </rng:choice>
                        </rng:optional>
                        <rng:zeroOrMore>
                            <rng:ref name="p"/>
                        </rng:zeroOrMore>
                        <rng:zeroOrMore>
                            <rng:ref name="bibl"/>
                        </rng:zeroOrMore>
                    </content>
                    <!--constraintSpec scheme="isoschematron" ident="sch-seal">
                        <desc>Attributes of tei:seal</desc>
                        <constraint>
                            <sch:pattern>
                                <sch:rule context="tei:seal">
                                    <sch:assert test="@n" xml:lang="en">The @n attribute must be
                                        specified on the <sch:name/> element.</sch:assert>
                                    <sch:assert test="@*[local-name() = 'condition']" xml:lang="en"
                                        >The @condition attribute must be specified on the
                                        <sch:name/> element.</sch:assert>
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec-->
                    <attList>
                        <!-- <attDef ident="n">
                            <datatype>
                                <rng:text/>
                            </datatype>
                        </attDef> -->
                        <attDef ident="material" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add">
                            <desc>material beschreibt das Material des Siegels</desc>
                            <valList type="closed">
                                <valItem ident="bulle">
                                    <desc xml:lang="de">Bulle</desc>
                                    <desc xml:lang="fr">bulle</desc>
                                </valItem>
                                <valItem ident="wafer">
                                    <desc xml:lang="de">Oblatensiegel</desc>
                                    <desc xml:lang="fr">sceau hostie</desc>
                                </valItem>
                                <valItem ident="papered seal">
                                    <desc xml:lang="de">Papierwachssiegel</desc>
                                    <desc xml:lang="fr">sceau sous papier</desc>
                                </valItem>
                                <valItem ident="sealing wax">
                                    <desc xml:lang="de">Siegellack</desc>
                                    <desc xml:lang="fr">cire pour le scellement</desc>
                                </valItem>
                                <valItem ident="wax">
                                    <desc xml:lang="de">Wachs</desc>
                                    <desc xml:lang="fr">cire</desc>
                                </valItem>
                                <valItem ident="wax in a box">
                                    <desc xml:lang="de">Wachs in Holzkapsel</desc>
                                    <desc xml:lang="fr">cire dans une caissette en bois</desc>
                                </valItem>
                                <valItem ident="wax with margin">
                                    <desc xml:lang="de">Wachs in Schüssel</desc>
                                    <desc xml:lang="fr">cire dans un bol</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="shape" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add">
                            <desc>shape beschreibt die Form des Siegels</desc>
                            <valList type="closed">
                                <valItem ident="octangular">
                                    <desc xml:lang="de">achteckig</desc>
                                    <desc xml:lang="fr">octongonal</desc>
                                </valItem>
                                <valItem ident="triangular">
                                    <desc xml:lang="de">dreieckig</desc>
                                    <desc xml:lang="fr">triangulaire</desc>
                                </valItem>
                                <valItem ident="heart-shaped">
                                    <desc xml:lang="de">herzförmig</desc>
                                    <desc xml:lang="fr">en forme de cœur</desc>
                                </valItem>
                                <valItem ident="round">
                                    <desc xml:lang="de">rund</desc>
                                    <desc xml:lang="fr">rond</desc>
                                </valItem>
                                <valItem ident="peltade">
                                    <desc xml:lang="de">schildförmig</desc>
                                    <desc xml:lang="fr">en forme de bouclier</desc>
                                </valItem>
                                <valItem ident="oval">
                                    <desc xml:lang="de">spitzoval</desc>
                                    <desc xml:lang="fr">ovale pointu</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="attachment" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add">
                            <desc>attachment beschreibt die Befestigungsart des Siegels</desc>
                            <valList type="closed">
                                <valItem ident="sealed on a ribbon">
                                    <desc xml:lang="de">angehängt an Band</desc>
                                    <desc xml:lang="fr">attaché à un ruban</desc>
                                </valItem>
                                <valItem ident="sealed on laces">
                                    <desc xml:lang="de">angehängt an Fäden</desc>
                                    <desc xml:lang="fr">attaché à un fil</desc>
                                </valItem>
                                <valItem ident="sealed on a leather tag">
                                    <desc xml:lang="de">angehängt an Lederstreifen</desc>
                                    <desc xml:lang="fr">attaché à une lanière en cuir</desc>
                                </valItem>
                                <valItem ident="sealed on a cord">
                                    <desc xml:lang="de">angehängt an einer Kordel</desc>
                                    <desc xml:lang="fr"></desc>
                                </valItem>
                                <valItem ident="sealed on a parchment tag">
                                    <desc xml:lang="de">angehängt an Pergamentstreifen</desc>
                                    <desc xml:lang="fr"></desc>
                                </valItem>
                                <valItem ident="sealed on a lace">
                                    <desc xml:lang="de">angehängt an Schnur</desc>
                                    <desc xml:lang="fr">attaché à un cordon</desc>
                                </valItem>
                                <valItem ident="applied">
                                    <desc xml:lang="de">aufgedrückt</desc>
                                    <desc xml:lang="fr">pressé (</desc>
                                </valItem>
                                <valItem ident="slit">
                                    <desc xml:lang="de">nur Siegelschlitz vorhanden</desc>
                                    <desc xml:lang="fr">il n'existe qu'une fente pour le sceau</desc>
                                </valItem>
                                <valItem ident="wrapping-tie">
                                    <desc xml:lang="de">zum Verschluss aufgedrückt</desc>
                                    <desc xml:lang="fr">sceau fermant le document</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="condition" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add"
                            usage="rec"> <!--usage="req"-->
                            <desc>condition beschreibt den Erhaltungszustand und Schäden des
                                Siegels</desc>
                            <valList type="closed">
                                <valItem ident="absent">
                                    <desc xml:lang="de">fehlt</desc>
                                	<desc xml:lang="fr">absent</desc>
                                </valItem>
                                <valItem ident="polished">
                                    <desc xml:lang="de">abgeschliffen</desc>
                                	<desc xml:lang="fr">poli</desc>
                                </valItem>
                                <valItem ident="ex and enclosed">
                                    <desc xml:lang="de">ab und beiliegend</desc>
                                	<desc xml:lang="fr">détaché et joint</desc>
                                </valItem>
                                <!-- PS: Weggelassen, da absent genügt mit Kombinatin @attachment <valItem ident="ex and absent">
                                    <desc xml:lang="de">ab und fehlend</desc>
                                </valItem> -->
                                <valItem ident="damaged">
                                    <desc xml:lang="de">beschädigt</desc>
                                	<desc xml:lang="fr">endommagé</desc>
                                </valItem>
                                <valItem ident="chamfered">
                                    <desc xml:lang="de">bestossen</desc>
                                	<desc xml:lang="fr">écorné</desc>
                                </valItem>
                                <valItem ident="fragmentary">
                                    <desc xml:lang="de">bruchstückhaft</desc>
                                	<desc xml:lang="fr">fragmentaire</desc>
                                </valItem>
                                <valItem ident="well-preserved">
                                    <desc xml:lang="de">gut erhalten</desc>
                                	<desc xml:lang="fr">bien conservé</desc>
                                </valItem>
                                <valItem ident="bound in linen">
                                	<desc xml:lang="de">in Leinensäckchen </desc>
                                	<desc xml:lang="fr">lié dans un sachet de lin</desc>
                                </valItem>
                                <valItem ident="in a box">
                                    <desc xml:lang="de">in verschlossener Holzkapsel</desc>
                                	<desc xml:lang="fr">dans une boîte en bois </desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="place" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add">
                            <desc>place gibt den Ort des Siegels an</desc>
                            <valList type="closed">
                                <valItem ident="end">
                                    <desc xml:lang="de">am Ende der Urkunde</desc>
                                    <desc xml:lang="fr">en bas de l'acte</desc>
                                </valItem>
                                <valItem ident="overleaf">
                                    <desc xml:lang="de">auf der anderen Seite des Blattes</desc>
                                    <desc xml:lang="fr">sur l'autre page de la feuille</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="extent" ns="http://ssrq-sds-fds.ch/ns/nonTEI" mode="add">
                            <desc>extent enthält die Abmessungen B/H bzw. den Durchmesser eines
                                Siegels in Millimeter (mm)</desc>
                            <!-- N, NN, NNN oder N/N, NN/NN, NNN/NNN  -->
                            <datatype>
                                <rng:text/>
                            </datatype>
                        </attDef>
                        <!-- <attDef ident="n" mode="replace" usage="req"/> -->
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="type" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- TEXT -->
                <!-- ebene 1 unterbaum TEI -->
                <elementSpec ident="text" module="textstructure" mode="change">
                    <content>
                        <rng:group>
                            <rng:optional>
                                <rng:ref name="front"/>
                            </rng:optional>
                            <rng:choice>
                                <rng:ref name="body"/>
                                <rng:ref name="group"/>
                            </rng:choice>
                            <rng:optional>
                                <rng:ref name="back"/>
                            </rng:optional>
                        </rng:group>
                    </content>
                </elementSpec>
                <!-- ebene 2 unterbaum text -->
                <elementSpec ident="back" module="textstructure" mode="change">
                    <!-- classes mode="replace">
                        <memberOf key="att.global.linking"/>
                        <!- @corresp ->
                        <memberOf key="att.global"/>
                    </classes> -->
                    <content>
                        <rng:zeroOrMore>
                            <rng:ref name="list"/>
                        </rng:zeroOrMore>
                        <rng:oneOrMore>
                            <rng:ref name="div"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="body" module="textstructure" mode="change">
                    <content>
                        <rng:group>
                            <rng:zeroOrMore>
                                <rng:choice>
                                    <rng:ref name="gap"/>
                                    <rng:ref name="pb"/>
                                    <rng:ref name="lb"/>
                                </rng:choice>
                            </rng:zeroOrMore>
                            <rng:group>
                                <rng:choice>
                                    <rng:oneOrMore>
                                        <rng:ref name="div"/>
                                        <rng:zeroOrMore>
                                            <rng:choice>
                                                <rng:ref name="gap"/>
                                                <rng:ref name="pb"/>
                                                <rng:ref name="lb"/>
                                            </rng:choice>
                                        </rng:zeroOrMore>
                                    </rng:oneOrMore>
                                    <rng:zeroOrMore>
                                        <rng:choice>
                                            <rng:ref name="div"/>
                                        </rng:choice>
                                        <rng:zeroOrMore>
                                            <rng:choice>
                                                <rng:ref name="gap"/>
                                                <rng:ref name="pb"/>
                                                <rng:ref name="lb"/>
                                            </rng:choice>
                                        </rng:zeroOrMore>
                                    </rng:zeroOrMore>
                                </rng:choice>
                            </rng:group>
                            <rng:zeroOrMore>
                                <rng:ref name="signed"/>
                            </rng:zeroOrMore>
                            <rng:zeroOrMore>
                                <rng:choice>
                                    <rng:ref name="gap"/>
                                    <rng:ref name="pb"/>
                                    <rng:ref name="lb"/>
                                </rng:choice>
                            </rng:zeroOrMore>
                        </rng:group>
                    </content>
                </elementSpec>
                <elementSpec ident="front" module="textstructure" mode="change">
                    <content>
                        <rng:optional>
                            <rng:zeroOrMore>
                                <rng:choice>
                                    <rng:ref name="p"/>
                                    <rng:ref name="head"/>
                                </rng:choice>
                            </rng:zeroOrMore>
                            <rng:oneOrMore>
                                <rng:ref name="div"/>
                            </rng:oneOrMore>
                        </rng:optional>
                    </content>
                </elementSpec>
                <elementSpec ident="group" module="textstructure" mode="change">
                    <content>
                        <rng:ref name="text"/>
                    </content>
                </elementSpec>
                <!-- ebene 3 unterbaum text/back -->
                <elementSpec ident="div" module="textstructure" mode="change">
                    <!-- classes mode="replace">
                        <memberOf key="model.divLike"/>
                        <memberOf key="att.typed"/>
                        <!- @type ->
                        <memberOf key="att.global"/>
                    </classes> -->
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="head"/>
                                <rng:ref name="p"/>
                                <rng:ref name="lb"/>
                                <rng:ref name="pb"/>
                                <rng:ref name="ab"/>
                                <rng:ref name="seg"/>
                                <rng:ref name="add"/>
                                <rng:ref name="addSpan"/>
                                <rng:ref name="table"/>
                                <!-- div in div erlaubt -->
                                <rng:ref name="div"/>
                                <rng:ref name="signed"/>
                                <rng:ref name="del"/>
                                <rng:ref name="delSpan"/>
                                <rng:ref name="damage"/>
                                <rng:ref name="damageSpan"/>
                                <rng:ref name="anchor"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="type" mode="replace">
                            <desc xml:lang="de">Nähere Bezeichnung von Textteilen</desc>
                            <valList type="closed">
                                <valItem ident="part">
                                    <desc xml:lang="de">Teil</desc>
                                    <desc xml:lang="fr">partie</desc>
                                </valItem>
                                <valItem ident="chapter">
                                    <desc xml:lang="de">Kapitel</desc>
                                    <desc xml:lang="fr">chapitre</desc>
                                </valItem>
                                <valItem ident="preliminary remark"><!-- Ergänzung für Andreas Ineichen -->
                                    <desc xml:lang="de">Vorbemerkung</desc>
                                </valItem>
                                <valItem ident="section">
                                    <desc xml:lang="de">Artikel</desc>
                                    <desc xml:lang="fr">article</desc>
                                </valItem>
                                <valItem ident="subsection">
                                    <desc xml:lang="de">Paragraph</desc>
                                    <desc xml:lang="fr">paragraphe</desc>
                                </valItem>
                            </valList>
                        </attDef>
                    </attList>
                </elementSpec>
                <elementSpec ident="list" module="core" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:optional>
                                <rng:ref name="label"/>
                            </rng:optional>
                            <rng:ref name="item"/>
                        </rng:oneOrMore>
                    </content>
                </elementSpec>
                <!-- ebene 3 unterbaum text/body -->
                <elementSpec ident="p" module="core" mode="change">
                    <classes mode="change">
                        <memberOf key="att.global.facs"/>
                    </classes>
                </elementSpec>
                <elementSpec ident="pb" module="core" mode="change">
                    <!--classes mode="replace">
                        <memberOf key="model.emphLike"/>
                        <memberOf key="att.typed"/>
                        <!- @type ->
                        <memberOf key="att.global"/>
                        <!- @facs, @n, @xml:lang ->
                    </classes> -->
                    <classes mode="change">
                        <memberOf key="att.global.facs"/>
                    </classes>
                    <content>
                        <rng:empty/>
                    </content>
                    <attList>
                        <attDef ident="break" mode="replace">
                            <desc/>
                            <valList type="closed">
                                <valItem ident="no">
                                    <desc/>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="spanTo" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="lb" module="core" mode="change">
                    <!-- classes mode="replace">
                        <memberOf key="model.milestoneLike"/>
                        <memberOf key="att.typed"/>
                        <!- @type ->
                        <memberOf key="att.global"/>
                    </classes> -->
                    <classes mode="change">
                        <memberOf key="att.global.facs"/>
                    </classes>
                    <content>
                        <rng:empty/>
                    </content>
                    <attList>
                        <attDef ident="break" mode="replace">
                            <desc/>
                            <valList type="closed">
                                <valItem ident="no">
                                    <desc/>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="spanTo" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="signed" module="textstructure" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="macro.defaultContent"/>
                                <rng:ref name="figure"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="gap" module="core" mode="change">
                    <content>
                        <rng:empty/>
                    </content>
                    <constraintSpec scheme="isoschematron" ident="sch-gap">
                        <desc>Attributes of tei:gap</desc>
                        <constraint>
                            <sch:pattern>
                                <sch:rule context="tei:gap[parent::tei:damage]">
                                    <sch:report test="@reason" xml:lang="en">If tei:gap is a child
                                        of tei:damage, @reason cannot be specififed on
                                        tei:gap.</sch:report>
                                </sch:rule>
                                <sch:rule context="tei:gap[not(parent::tei:damage) and @reason]">
                                    <sch:report
                                        test="@reason = 'illegible' and (not(@unit) or not(@quantity))"
                                        >If @reason is specified on the <sch:name/> element and its
                                        value is "illegible", @unit and @quantity must be present,
                                        too.</sch:report>
                                    <sch:report test="@source">On the <sch:name/> element, @source
                                        cannot occur together with @reason. Those attributes are
                                        mutually exclusive.</sch:report>
                                </sch:rule>
                                <sch:rule context="tei:gap[not(parent::tei:damage) and @source]">
                                    <sch:report test="@unit or @quantity or @reason">If @source is
                                        specified on the <sch:name/> element, @unit, @quantity and
                                        @reason are forbidden.</sch:report>
                                    <!--  fakultativ <sch:assert test="following-sibling::*[position() = 1 and self::tei:note]"
                                        >If @source is specified on the <sch:name/> element, the <sch:name/> element must be immediately followed by a tei:note element.</sch:assert> -->
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec>
                    <attList>
                        <attDef ident="reason" mode="replace">
                            <desc xml:lang="de">Grund der Lücke</desc>
                            <valList type="closed">
                                <valItem ident="illegible">
                                    <desc xml:lang="de">unleserlich</desc>
                                    <desc xml:lang="fr">illisible</desc>
                                </valItem>
                                <valItem ident="irrelevant">
                                    <desc xml:lang="de">irrelevant</desc>
                                    <desc xml:lang="fr">insignifiant</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <!-- 4 Attribute zulassen: @unit mit character, cm, line und word; @quantity und @source-->
                        <attDef ident="unit" mode="replace">
                            <desc xml:lang="de">Angabe zur Masseinheit</desc>
                            <desc xml:lang="fr">indication de l’unité de mesure</desc>
                            <valList type="closed">
                                <valItem ident="character">
                                    <desc xml:lang="de">Buchstabe</desc>
                                    <desc xml:lang="fr">lettre</desc>
                                </valItem>
                                <valItem ident="cm">
                                    <desc xml:lang="de">cm</desc>
                                    <desc xml:lang="fr">cm</desc>
                                </valItem>
                                <valItem ident="line">
                                    <desc xml:lang="de">Zeile</desc>
                                    <desc xml:lang="fr">ligne</desc>
                                </valItem>
                                <valItem ident="word">
                                    <desc xml:lang="de">Wort</desc>
                                    <desc xml:lang="fr">mot</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="agent" mode="delete"/>
                        <attDef ident="hand" mode="delete"/>
                        <attDef ident="resp" mode="delete"/>
                        <attDef ident="cert" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="extent" mode="delete"/>
                        <attDef ident="precision" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 3 unterbaum text/front -->
                <elementSpec ident="head" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:ref name="macro.defaultContent"/>
                                <rng:ref name="anchor"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="type" mode="replace">
                            <desc/>
                            <valList type="closed">
                                <valItem ident="title">
                                    <desc xml:lang="de">Haupttitel</desc>
                                    <desc xml:lang="fr">titre principal</desc>
                                </valItem>
                                <valItem ident="subtitle">
                                    <desc xml:lang="de">Untertitel</desc>
                                    <desc xml:lang="fr">sous-titre</desc>
                                </valItem>
                            </valList>
                        </attDef>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 4 unterbaum text/div/ -->
                <elementSpec ident="table" module="figures" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="head"/>
                                <rng:ref name="row"/>
                                <rng:ref name="pb"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="cols" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="rows" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 4 unterbaum text/back/list -->
                <elementSpec ident="item" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec>
                <elementSpec ident="label" module="core" mode="change">
                    <content>
                        <rng:ref name="macro.defaultContent"/>
                    </content>
                </elementSpec>
                <!-- ebene 4 unterbaum text/body/p -->
                <elementSpec ident="foreign" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <attList>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 4 unterbaum text/body/signed -->
                <elementSpec ident="handShift" module="transcr" mode="change">
                    <content>
                        <rng:empty/>
                    </content>
                    <attList>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="medium" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="new" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="resp" mode="delete"/>
                    </attList>
                </elementSpec>
                <elementSpec ident="figure" module="figures" mode="change">
                    <content>
                        <rng:empty/>
                    </content>
                    <attList>
                        <attDef ident="type" mode="replace" usage="req">
                            <desc/>
                            <valList type="closed">
                                <valItem ident="copper engraving ">
                                    <desc xml:lang="de">Kupferstich</desc>
                                    <desc xml:lang="fr">gravure sur cuivre</desc>
                                </valItem>
                                <valItem ident="drawing">
                                    <desc xml:lang="de">Federzeichnung</desc>
                                    <desc xml:lang="fr">dessin à la plume</desc>
                                </valItem>
                                <valItem ident="locus sigilli">
                                    <desc xml:lang="de">Locus sigilli</desc>
                                    <desc xml:lang="fr">locus sigilli</desc>
                                </valItem>
                                <valItem ident="notarial sign">
                                    <desc xml:lang="de">Notarzeichen</desc>
                                    <desc xml:lang="fr">seing notariel</desc>
                                </valItem>
                                <valItem ident="sign">
                                    <desc xml:lang="de">Verweiszeichen</desc>
                                    <desc xml:lang="fr">signe de renvoi </desc>
                                </valItem>
                            	<valItem ident="woodcut">
				<desc xml:lang="de">Holzschnitt</desc>
                            	    <desc xml:lang="fr">gravure sur bois</desc>
                            	</valItem>
                            </valList>
                        </attDef>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="place" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 4 unterbaum text/front/head -->
                <!--  <elementSpec ident="orig" module="core" mode="change">
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="unclear"/>
                                <rng:ref name="choice"/>
                                <rng:ref name="gap"/>
                                <rng:ref name="damage"/>
                                <rng:ref name="del"/>
                                <rng:ref name="abbr"/>
                                <rng:ref name="add"/>
                                <rng:ref name="sic"/>
                                <rng:ref name="p"/>
                                <rng:ref name="lb"/>
                                <rng:ref name="note"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                </elementSpec> -->
                <!-- ebene 4 unterbaum text/body/p -->
                <!-- ebene 5 unterbaum text/back/div/table -->
                <elementSpec ident="row" module="figures" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:ref name="cell"/>
                        </rng:oneOrMore>
                    </content>
                    <attList>
                        <attDef ident="role" mode="delete"/>
                        <attDef ident="cols" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="rows" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- ebene 6 unterbaum text/back/div/table/row -->
                <elementSpec ident="cell" module="figures" mode="change">
                    <content>
                        <rng:oneOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:oneOrMore>
                    </content>
                    <attList>
                        <attDef ident="cols" mode="delete"/>
                        <attDef ident="corresp" mode="delete"/>
                        <attDef ident="n" mode="delete"/>
                        <attDef ident="rend" mode="delete"/>
                        <attDef ident="rows" mode="delete"/>
                    </attList>
                </elementSpec>
                <!-- NICHT IN BAUM - alphabetisch -->
                <elementSpec ident="ab" module="linking" mode="change">
                    <classes mode="change">
                        <!-- because of @scribe -->
                        <memberOf key="att.handFeatures"/>
                    </classes>
                    <content>
                        <rng:zeroOrMore>
                            <rng:choice>
                                <rng:text/>
                                <rng:ref name="macro.defaultContent"/>
                            </rng:choice>
                        </rng:zeroOrMore>
                    </content>
                    <constraintSpec scheme="isoschematron" ident="sch-ab">
                        <desc>number of ab elements within div</desc>
                        <constraint>
                            <sch:pattern>
                                <sch:rule context="tei:ab">
                                    <sch:assert test="count(parent::tei:div/tei:ab) = 1"
                                        xml:lang="en">There can only be one <sch:name/> element
                                        within &lt;div&gt;.</sch:assert>
                                    <sch:assert test="count(parent::tei:div/*) = 1" xml:lang="en"
                                        >The <sch:name/> element must be the only element within
                                        &lt;div&gt;.</sch:assert>
                                    <!--<sch:assert test="name(./../..) = 'body'" xml:lang="en"
                                        >The <sch:name/> element must be the grandchild of body: body/div/<sch:name/>.</sch:assert>-->
                                </sch:rule>
                            </sch:pattern>
                        </constraint>
                    </constraintSpec>
                    <attList>
                        <attDef ident="type" mode="replace" usage="req">
                            <desc/>
                            <valList type="closed">
                                <valItem ident="address">
                                    <desc xml:lang="de">Anschrift</desc>
                                    <desc xml:lang="fr">adresse</desc>
                                </valItem>
                                <valItem ident="dorsal">
                                    <desc xml:lang="de">Vermerk</desc>
                                    <desc xml:lang="fr">note dorsale</desc>
                                </valItem>
                                <valItem ident="chancery notation">
                                    <desc xml:lang="de">Kanzleivermerk</desc>
                                    <desc xml:lang="fr">annotation issue d'une chancellerie</desc>
                                </valItem>
                                <valItem ident="archiving reference">
                                    <desc xml:lang="de">Registraturvermerk</desc>
                                    <desc xml:lang="fr">annotation issue de la Registratur</desc>
                                </valItem>
                                <valItem ident="computatio">
                                    <desc xml:lang="de">Komputierungsvermerk</desc>
                                    <desc xml:lang="fr">annotation du computeur</desc>
                                </valItem>
                                <valItem ident="sigillant">
                                    <desc xml:lang="de">Sieglervermerk</desc>
