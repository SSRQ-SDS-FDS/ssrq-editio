%% == Required ==
%% In order to avoid an option clash, we don't load 'lineno' 
%% right here, but throw an error when it has not been loaded:
\@ifpackageloaded{lineno}{}{%
    \PackageError{getlno}%
                 {Package `lineno' not yet loaded}%
                 {Reorder \string\usepackage\space commands 
                  in your document preamble\MessageBreak 
                  to load `lnindex.sty' after `lineno.sty'.}
}
%%
%% == Getting Rid of \cs{getpagewiselinenumber} == 
%% This code has essentially been written 2004-11-25 
%% in a file `LIdxTest.tex' for Sergei Mariev.
%% It used `\@LN@getlineno' where we use `\getLineNumber' here. 
%% I decided for the latter change because it should be little 
%% dangerous and is more close to Stephan's original 
%% well-readable style in 'lineno.sty'.
%% 
%% 'lineno.sty''s |\WriteLineNo| gets `\getLineNumber'
%% in the second argument of `\protectd@write' being
%% executed in a local group to prepare `\write':
\def\WriteLineNo{% 
  \unvbox\@cclv 
  \expandafter \@LN@xnext \@LN@labellist \@@ 
                          \@LN@label \@LN@labellist 
  \protected@write\@auxout\getLineNumber 
        {\string\newlabel{\@LN@label}% 
         {{\thelinenumber}{\thepage}\@LN@ExtraLabelItems}}% 
}
%% `\getLineNumber' does nothing when used with running line numbers:
\def\setrunninglinenumbers{%
%    \def\theLineNumber{\thelinenumber}%
   \let\getLineNumber\relax 
   \let\c@linenumber\c@runninglinenumber
   \let\makeLineNumber\makeRunningLineNumber
   }
%% With pagewise line numbers, `\getLineNumber' is 
%% 'lineno''s `\testNumberedPage' that applies an offset 
%% to the line number counter:
\def\setpagewiselinenumbers{%
%    \let\theLineNumber\thePagewiseLineNumber
   \let\getLineNumber\testNumberedPage 
   \let\c@linenumber\c@pagewiselinenumber
   \let\makeLineNumber\makePagewiseLineNumber
   }
%% What seems to be no longer needed is undefined:
\let\theLineNumber\@undefined 
\let\thePagewiseLineNumber\@undefined 
\let\getpagewiselinenumber\@undefined 
%% When 'lineno.sty' has been loaded earlier, 
%% \ `\setrunninglinenumbers' \ or \ `\setpagewiselinenumbers' \
%% has been executed. We repeat the last one to choose 
%% the meaning of `\getLineNumber' needed accordingly:
\ifx\c@linenumber\c@runninglinenumber 
  \setrunninglinenumbers 
\else 
  \setpagewiselinenumbers 
\fi 
%%
%% == Adjusting 'edtable.sty' ==
%% 'edtable.sty'---which allows modifying tabular environments 
%% to apply line numbering to their rows---has used 
%% `\theLineNumber' so far and must be modified accordingly. 
%% As follows, a ``patch" is applied when it is detected:
\AtBeginDocument{%
    \@ifpackageloaded{edtable}{%
%% The following rather is a general patch for 'edtable' 
%% which should have kept the `\linelabel' error 
%% when not numbering lines---TODO:
        \renewcommand*\@ET@trivialize@linelabel{%
            \let\@LN@linelabel\@ET@linelabel}
%% The change specifically for 'getpwlno' is a new definition 
%% of `\@ET@linelabel'. `\getLineNumber' is run in a group 
%% before preparing the `\label'. Also, there are `\@bsphack'
%% and `\@esphack', missing in 'edtable.sty'---TODO:
        \def\@ET@linelabel#1{%
            \@bsphack
            \begingroup
                \getLineNumber
                \protected@edef\@currentlabel{\thelinenumber}%
                \label{#1}%
            \endgroup
            \@esphack}%
    }\relax             %% ... without `edtable.sty'
}
