\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{pagenote}[2009/09/03 v1.1a page/end notes]
\@ifclassloaded{memoir}{}{\RequirePackage{ifmtarg}}

\newif\ifpnhaschapter
\@ifundefined{chapter}{\pnhaschapterfalse}{\pnhaschaptertrue}

\providecommand{\f@rtoc}{}

\newif\ifpnpageopt
  \pnpageoptfalse
\newif\ifpncontopt
  \pncontoptfalse

\DeclareOption{page}{\pnpageopttrue}
\DeclareOption{continuous}{\pncontopttrue}
\ProcessOptions

\ifpncontopt
  \newcounter{pagenote}
\else
  \ifpnhaschapter
    \newcounter{pagenote}[chapter]
  \else
    \newcounter{pagenote}[section]
  \fi
\fi
\renewcommand{\thepagenote}{\arabic{pagenote}}
\setcounter{pagenote}{0}
\newcounter{pnotesavechap}
  \setcounter{pnotesavechap}{-1000}

\newif\ifmakingpagenotes
  \makingpagenotesfalse

\newcommand*{\makepagenote}{%
  \newwrite\@tnotefile
  \immediate\openout\@tnotefile=\jobname.text.ent
  \newwrite\@enotefile
  \immediate\openout\@enotefile=\jobname.ed.ent
  \makingpagenotestrue
  \def\textnote{\@bsphack\begingroup
    \@sanitize
    \@wrtnote}%
  \def\textnotestart{\@bsphack\begingroup
    \@sanitize
    \@wrtnotes}%
  \def\ednote{\@bsphack\begingroup
    \@sanitize
    \@wrenote}%
  \typeout{Writing note files \jobname.text.ent and \jobname.ed.ent}%
  \let\makepagenote\@empty}

\newcommand{\immediate@protected@write}[3]{%
  \begingroup
  #2%
  \let\protect\@unexpandable@protect
  \edef\reserved@a{\immediate\write#1{#3}}%
  \reserved@a
  \endgroup
  \if@nobreak\ifvmode\nobreak\fi\fi}

\ifpnpageopt
  \let\@pnwrite\protected@write
\else
  \let\@pnwrite\immediate@protected@write
\fi

\newcommand{\@wrtnote}[2][]{%
  \refstepcounter{pagenote}%
  \notenumintext{#1}%
  \@pnwrite\@tnotefile{}
    {\string\noteentry{\thepagenote}{#1}{#2}{\thepage}}%
  \endgroup
  \@esphack}

\def\textnote{\@bsphack\begingroup \@sanitize\@textnote}

\newcommand{\@textnote}[2][]{\endgroup\@esphack}

\newcommand{\@wrtnotes}[2]{%
  \refstepcounter{pagenote}%
  \notenumintext{#1–}%
  \@pnwrite\@tnotefile{}
    {\string\noteentry{\thepagenote}{#1}{#2}{\thepage}}%
  \endgroup
  \@esphack}

\def\textnotestart{\@bsphack\begingroup \@sanitize\@textnotestart}

\newcommand{\@textnotestart}[2]{\endgroup\@esphack}

\newcommand{\textnoteend}[1]{%
  \textsuperscript{\textup{–#1}}}

\newcommand{\repeatednote}[1]{%
  \textsuperscript{\textup{#1}}}

\newcommand{\@wrenote}[2][]{%
  \refstepcounter{pagenote}%
  \notenumintext{#1}%
  \@pnwrite\@enotefile{}
    {\string\noteentry{\thepagenote}{#1}{#2}{\thepage}}%
  \endgroup
  \@esphack}

\def\ednote{\@bsphack\begingroup \@sanitize\@ednote}

\newcommand{\@ednote}[2][]{\endgroup\@esphack}

\newcommand{\notenumintext}[1]{%
  \textsuperscript{#1}}
\newcommand{\notenuminnotes}[1]{%
  {\normalfont #1.} }
\newcommand{\noteentry}[4]{%
  \prenoteinnotes
  \noteidinnotes{#1}{#2}\pageinnotes{#4}\noteinnotes{#3}%
  \postnoteinnotes}

\newcommand{\textinnotes}[1]{%
  [#1] }
\newcommand{\noteidinnotes}[2]{%
  \@ifmtarg{#2}{%
    \notenuminnotes{#1}}{\textinnotes{#2}}}
\providecommand*{\pagename}{page}
\newcommand{\pageinnotes}[1]{%
  \ifpnpageopt (\pagename\ #1) \fi}
\newcommand{\noteinnotes}[1]{#1}

\newcommand{\prenoteinnotes}{\par\noindent}
\newcommand{\postnoteinnotes}{\par}
\newcommand{\textedsep}{\vspace{1.5ex}}

\newread\reader
\def\eolmarker{\par}
\newcommand{\conditionaltextedsep}{%
  \openin\reader=\jobname.ed.ent\relax
  \read\reader to \readmacro
  \ifeof\reader
    \ifx\readmacro\eolmarker
      \typeout{\jobname.ed.ent is empty}%
    \else
      \typeout{\jobname.ed.ent is not empty}%
      \textedsep
    \fi
  \else
      \typeout{\jobname.ed.ent is not empty}%
      \textedsep
  \fi
  \closein\reader
}


\providecommand*{\notesname}{Notes}
\ifpnhaschapter
  \newcommand*{\notedivision}{\chapter{\notesname}}
\else
  \newcommand*{\notedivision}{\section{\notesname}}
\fi

\newcommand*{\printnotes}{\@ifstar{\@sprintnotes}{\@printnotes}}
\newcommand*{\pnofilewarn}{%
  \PackageWarning{pagenote}{There is no .ent file}}
\newcommand*{\@sprintnotes}{%
  \ifmakingpagenotes
  \notedivision
\IfFileExists{\jobname.text.ent}{%
  \immediate\closeout\@tnotefile
  \input{\jobname.text.ent}%
  \immediate\openout\@tnotefile=\jobname.text.ent%
  }{%
  \pnofilewarn
}%
\IfFileExists{\jobname.ed.ent}{%
  \immediate\closeout\@enotefile
  \conditionaltextedsep
  \input{\jobname.ed.ent}%
  \immediate\openout\@enotefile=\jobname.ed.ent%
  }{%
  \pnofilewarn
}%
\fi}

\newcommand*{\@printnotes}{%
  \ifmakingpagenotes
  \notedivision
\IfFileExists{\jobname.text.ent}{%
  \immediate\closeout\@tnotefile
  \input{\jobname.text.ent}%
  }{%
  \pnofilewarn
}%
\IfFileExists{\jobname.ed.ent}{%
  \immediate\closeout\@enotefile
  \conditionaltextedsep
  \input{\jobname.ed.ent}%
  }{%
  \pnofilewarn
}
\fi}

\providecommand*{\chaptername}{Chapter}
\providecommand*{\sectionname}{Section}
\ifpnhaschapter
  \DeclareRobustCommand{\pagenotesubhead}[2]{%
    \subsection*{\chaptername\ #1 #2}}
\else
  \DeclareRobustCommand{\pagenotesubhead}[2]{%
    \subsection*{\sectionname\ #1}}
\fi

\endinput
