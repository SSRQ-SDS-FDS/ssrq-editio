%% 
%% == Adjusting Error Handling ==
%% The error message |\@LN@LLerror| 
%% (reminding that line numbering mode is required) 
%% must be adjusted, too:
\def\@LN@LLerror{\PackageError{writelno}{%              %% v0.4
  Line number reference without \string\linenumbers}{% 
  See the lineno package documentation                  %% v0.41
  for \string\linenumbers\space and                     %% v0.6
  \string\begin{linenumbers}.}\@gobble}
%%
%% == Reimplementing \cs{linelabel} ==
%% \label{sec:ll}
%% |\linelabel{<string>}| is reimplemented via `\withlinenumber':
\renewcommand*{\linelabel}[1]{%
    \withlinenumber{\protected@write\@auxout{}{%
        \string\newlabel{#1}{{\thelinenumber}{\thepage}%
                             \@LN@ExtraLabelItems}}}}
%% \begin{trivlist}             \labelsep=0pt
%% \item[\bf With \cs{linenumberwrite}:]\
%% \begin{small}
%% \begin{verbatim}
%%     \renewcommand*{\linelabel}[1]{%
%%         \linenumberwrite{%
%%             \newlabel{#1}{{\thelinenumber}{\thepage}%
%%                           \@LN@ExtraLabelItems}}}%
%% \end{verbatim}
%% \end{small}
%% ... saves 7 tokens, but `\linenumberwrite' is expensive ...
%% \end{trivlist}
%%
%% == Support for 'edtable.sty' ==
%% v0.6 supports 'edtable.sty' for line numbers with tables 
%% (available from 
%%  \httpref{mirror.ctan.org/macros/latex/contrib/lineno/}{\acro{CTAN}} 
%%  together with \CtanPkgRef{lineno}{lineno.sty})---still 
%% somewhat experimental. This is the same as support for 
%% 'lineno.sty''s package option `[edtable]'.
%% `\@ET@trivialize@linelabel'
%% is modified in case 'edtable.sty' is detected. 
%% % The line number counter is incremented locally, 
%% % and `\theLineNumber' is replaced:
\AtBeginDocument{%
    \@ifpackageloaded{edtable}{%
%% 'getpwlno.sty' v0.4 already redefines `\@ET@trivialize@linelabel', 
%% but here we do the same in a different way: 
        \renewcommand*\@ET@trivialize@linelabel{%
            \let\@LN@withlinenumber\@ET@withlineno}%
%% ``Trivialization" means that `.aux' output is prepared
%% immediately, without waiting for the `\output' routine:
        \def\@ET@withlineno#1{%
            \@bsphack{\getLineNumber #1}\@esphack}%
%% This way and with the reimplementation of `\linelabel' in 
%% Section~\ref{sec:ll}, there is no need to redefine `\linelabel' 
%% for tables, 
%% as opposed to how '\mbox{getpwlno.sty}' supports 'edtable.sty'.
    }\relax         %% ... without `edtable.sty'
}
