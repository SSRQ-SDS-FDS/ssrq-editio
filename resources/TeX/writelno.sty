%% \[\hbox{\small
%%     `\PostponeVadjust{\getLineNumber\advance\c@counter\m@ne<code>}'}\]
%% However, this would be wrong when the same line launches a 
%% `\linebreak' earlier. The page number according to the entry 
%% then would be increased by~1, and the pagewise line number would 
%% be~``0."     %% -- -> ~ 2012/07/01; %% 2012/06/29:
