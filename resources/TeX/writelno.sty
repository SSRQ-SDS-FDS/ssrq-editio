%% == Required ==
%% % We use a version of 'lineno.sty' that avoids using the old 
%% % `\getpagewiselinenumbers' by a more recent
%% % `\getLineNumber' ('getpwlno.sty' v0.4):
%% We use  `\getLineNumber' to avoid `\getpagewiselinenumbers'. 
%% It is provided by 'getpwlno.sty' v0.4:
\RequirePackage{getpwlno}[2012/07/13]
%% 'getpwlno.sty' also ensures that 'lineno.sty' has been 
%% loaded earlier.
%%
%% == Generalizing Writing Line Numbers ==
%% \label{sec:wln}
%% We abuse |\WriteLineNo| for writing other `.aux' entries 
%% than `\newlabel's and `\@LN@label' to carry an entire 
%% writing command:
\renewcommand*{\WriteLineNo}{%
  \unvbox\@cclv
  \expandafter \@LN@xnext \@LN@labellist \@@
                          \@LN@label \@LN@labellist
%% `\getLineNumber' is to generalize the method from 'getpwlno.sty':
  {\getLineNumber \@LN@label}}
%% Now `\linelabel' needs a new implementation ...  %% v0.3a
%% 
%% |\withlinenumber{<code>}| resembles the original `\linelabel', 
%% we are replacing `\@LN@linelabel' by 
%% `\@LN@withlinenumber'.\footnote{v0.4 turns \cs{linenumberwrite} 
%%                                  into \cs{withlinenumber}} 
%% <code> replaces the <string> argument of the former 
%% `\linelabel'. The macro name reflects what the macro does, 
%% namely adjusting the line number counter so that 
%% `\thelinenumber' (or something more general like 
%% `\arabic{linenumber}') when appearing in <code> 
%% displays the line number of the 
%% line to which the code nearby contributes:
\newcommand\withlinenumber{% 
  \ifLineNumbers \expandafter \@LN@withlinenumber 
           \else \expandafter \@LN@LLerror     \fi}
%% |\@LN@withlinenumber| formerly was `\@LN@linelabel':
\global\let\@LN@withlinenumber\@LN@linelabel
%% (v0.2                                    %% v0.3a: was v0.3
%%  copied the code instead of the meaning.)
%% `\@LN@withlinenumber' thus invokes many facilities to hide 
%% the `\write' instruction typographically. It handles the <code>
%% argument by `\@LN@postlabel{<code>}'. This attaches <code>
%% to the original line label list and sets a signal penalty.
%% <code> will then be carried out by `\WriteLineNo'.
%%
%% I thought of using 'lineno.sty''s `\@LN@linelabel' as an 
%% ``abstraction layer" here, but               %% 2012/07/01:
\let\@LN@linelabel\@undefined
%%
%% %% v0.4 2012/06/28:
